<Window x:Class="GlDrive.UI.RevertRunsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revert AI Runs" Width="700" Height="500"
        MinWidth="550" MinHeight="350"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
  <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
    <DockPanel>
      <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
        <TextBlock Text="&gt;&gt; REVERT RUNS" Style="{DynamicResource SectionHeaderTextStyle}"/>
      </Border>
      <Grid Margin="12">
        <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
        <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
        <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
        <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Text="Select runs to revert. Each reverses every applied change from that run." TextWrapping="Wrap"/>
          <ListBox Grid.Row="1" x:Name="RunList" SelectionMode="Multiple" Margin="0,8" DisplayMemberPath="Label"/>
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Revert selected" Width="140" Click="Revert_Click"/>
          </StackPanel>
        </Grid>
      </Grid>
    </DockPanel>
  </Border>
</Window>
