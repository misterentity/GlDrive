<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BackgroundBrush" Color="#03070D"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#0B1828"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="#0F2238"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#15324E"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#D6ECFF"/>
    <SolidColorBrush x:Key="ForegroundDimBrush" Color="#6F8FAE"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#00E5FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#5EF3FF"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#0A2A36"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#04141B"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFAB1F"/>
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#3B0A14"/>
    <Color x:Key="AccentColor">#00E5FF</Color>

    <SolidColorBrush x:Key="Background0Brush" Color="#03070D"/>
    <SolidColorBrush x:Key="Background1Brush" Color="#070F1C"/>
    <SolidColorBrush x:Key="Background2Brush" Color="#0B1828"/>
    <SolidColorBrush x:Key="Background3Brush" Color="#0F2238"/>
    <SolidColorBrush x:Key="LineBrush" Color="#15324E"/>
    <SolidColorBrush x:Key="LineDimBrush" Color="#1C4368"/>
    <SolidColorBrush x:Key="TextBrush" Color="#D6ECFF"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="#6F8FAE"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="#355168"/>
    <SolidColorBrush x:Key="SignatureBrush" Color="#00E5FF"/>
    <SolidColorBrush x:Key="Signature2Brush" Color="#FF2AB8"/>
    <SolidColorBrush x:Key="GoodBrush" Color="#7CFF66"/>
    <SolidColorBrush x:Key="BadBrush" Color="#FF3F63"/>
    <SolidColorBrush x:Key="WarnBrush" Color="#FFAB1F"/>

    <Color x:Key="SignatureColor">#00E5FF</Color>
    <Color x:Key="Signature2Color">#FF2AB8</Color>

    <FontFamily x:Key="MonoFontFamily">Cascadia Mono, Consolas, Menlo, monospace</FontFamily>
    <FontFamily x:Key="DisplayFontFamily">Segoe UI Semibold, Rajdhani, sans-serif</FontFamily>

    <DropShadowEffect x:Key="SignatureGlowEffect" Color="#00E5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.65"/>
    <DropShadowEffect x:Key="Signature2GlowEffect" Color="#FF2AB8" BlurRadius="14" ShadowDepth="0" Opacity="0.55"/>
    <DropShadowEffect x:Key="SignatureGlowSoftEffect" Color="#00E5FF" BlurRadius="22" ShadowDepth="0" Opacity="0.35"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style x:Key="CyberpunkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LineDimBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="FontFamily" Value="{DynamicResource MonoFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="Bd" Property="Effect" Value="{DynamicResource SignatureGlowEffect}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CyberpunkPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource CyberpunkButtonStyle}">
        <Setter Property="Background" Value="#1A00E5FF"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
    </Style>

    <Style x:Key="CyberpunkFrameStyle" TargetType="Border">
        <Setter Property="Background" Value="#D90B1828"/>
        <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="CyberpunkFrameTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource DisplayFontFamily}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Padding" Value="14,10,14,8"/>
    </Style>
</ResourceDictionary>
