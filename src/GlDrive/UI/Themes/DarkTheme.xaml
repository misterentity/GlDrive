<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BackgroundBrush" Color="#111111"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1C1C1C"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="#282828"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E8E8E8"/>
    <SolidColorBrush x:Key="ForegroundDimBrush" Color="#888888"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#E53935"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF5252"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#4E1A1A"/>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#2A1515"/>
    <Color x:Key="AccentColor">#E53935</Color>
</ResourceDictionary>
