<Window x:Class="GlDrive.UI.ServerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Configuration" Width="460" Height="800"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Server Name:" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,8"/>

                <TextBlock Text="Host:" Margin="0,0,0,4"/>
                <TextBox x:Name="HostBox" Margin="0,0,0,8"/>

                <TextBlock Text="Port:" Margin="0,0,0,4"/>
                <TextBox x:Name="PortBox" Text="1337" Width="100" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <TextBlock Text="Username:" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,8"/>

                <TextBlock Text="Password:" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"/>

                <TextBlock Text="Root Path:" Margin="0,0,0,4"/>
                <TextBox x:Name="RootPathBox" Text="/" Margin="0,0,0,12"/>

                <Separator Margin="0,0,0,12"/>

                <!-- SOCKS5 Proxy -->
                <TextBlock Text="SOCKS5 Proxy" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox x:Name="ProxyEnabledBox" Content="Connect via SOCKS5 proxy" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Proxy Host:" Margin="0,0,0,2"/>
                        <TextBox x:Name="ProxyHostBox" Margin="0,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Port:" Margin="0,0,0,2"/>
                        <TextBox x:Name="ProxyPortBox" Text="1080"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Proxy Username (optional):" Margin="0,0,0,2"/>
                        <TextBox x:Name="ProxyUsernameBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Proxy Password:" Margin="0,0,0,2"/>
                        <PasswordBox x:Name="ProxyPasswordBox"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,4,0,12"/>

                <TextBlock Text="Drive Letter:" Margin="0,0,0,4"/>
                <ComboBox x:Name="DriveLetterBox" Width="80" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <TextBlock Text="Volume Label:" Margin="0,0,0,4"/>
                <TextBox x:Name="VolumeLabelBox" Text="glFTPd" Margin="0,0,0,8"/>

                <CheckBox x:Name="MountDriveBox" Content="Mount as drive letter" IsChecked="True" Margin="0,8,0,4"/>
                <CheckBox x:Name="AutoMountBox" Content="Auto-connect on start" IsChecked="True" Margin="0,0,0,8"/>
                <CheckBox x:Name="PreferTls12Box" Content="Prefer TLS 1.2 (recommended for glftpd)" IsChecked="True" Margin="0,0,0,8"/>

                <TextBlock Text="Speed Limit (KB/s, 0=use global):" Margin="0,0,0,4"/>
                <TextBox x:Name="SpeedLimitBox" Text="0" Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                <Separator Margin="0,0,0,12"/>

                <!-- Cache Settings -->
                <TextBlock Text="Cache" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,4">
                        <TextBlock Text="Directory TTL (sec):" Margin="0,0,0,2"/>
                        <TextBox x:Name="CacheTtlBox" Text="30" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Text="Max Cached Dirs:" Margin="0,0,0,2"/>
                        <TextBox x:Name="MaxCachedDirsBox" Text="500" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,0">
                        <TextBlock Text="File Info Timeout (ms):" Margin="0,0,0,2"/>
                        <TextBox x:Name="FileInfoTimeoutBox" Text="1000" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <!-- Pool Settings -->
                <TextBlock Text="Connection Pool" FontWeight="SemiBold" Margin="0,8,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Max Connections:" Margin="0,0,0,2"/>
                        <TextBox x:Name="PoolSizeBox" Text="3" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Keepalive (sec):" Margin="0,0,0,2"/>
                        <TextBox x:Name="KeepaliveBox" Text="30" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <!-- Notification Settings -->
                <TextBlock Text="Notifications" FontWeight="SemiBold" Margin="0,8,0,8"/>
                <CheckBox x:Name="NotificationsEnabledBox" Content="Enable new release notifications" IsChecked="True" Margin="0,0,0,8"/>
                <TextBlock Text="Excluded Categories (comma-separated):" Margin="0,0,0,2"/>
                <TextBox x:Name="ExcludedCategoriesBox" Margin="0,0,0,8"
                         ToolTip="e.g. xxx-paysite, 0day — these categories won't trigger notifications"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Poll Interval (sec):" Margin="0,0,0,2"/>
                        <TextBox x:Name="PollIntervalBox" Text="60" Width="80" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Watch Path:" Margin="0,0,0,2"/>
                        <TextBox x:Name="WatchPathBox" Text="/recent" HorizontalAlignment="Left" Width="140"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,4,0,12"/>

                <!-- Search Settings -->
                <TextBlock Text="Search" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Search Paths (one per line):" Margin="0,0,0,2"/>
                <TextBox x:Name="SearchPathsBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         Text="/" ToolTip="Directories to search for releases, e.g. /site&#x0a;/archive"/>
                <TextBlock Text="Search Method:" Margin="0,0,0,4"/>
                <ComboBox x:Name="SearchMethodBox" Width="160" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Max Depth:" Margin="0,0,0,2"/>
                        <TextBox x:Name="SearchMaxDepthBox" Text="2" Width="60" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Index Refresh (min):" Margin="0,0,0,2"/>
                        <TextBox x:Name="IndexCacheMinutesBox" Text="60" Width="60" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <Button Content="Discover Paths" Click="DiscoverPaths_Click"
                                HorizontalAlignment="Left" Padding="16,6"/>
                    </StackPanel>
                </Grid>
                <TextBlock x:Name="DiscoverResultText" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <Separator Margin="0,4,0,12"/>

                <!-- IRC Settings -->
                <TextBlock Text="IRC" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <CheckBox x:Name="IrcEnabledBox" Content="Enable IRC client" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="IRC Host:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcHostBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Port:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcPortBox" Text="6697"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="IrcUseTlsBox" Content="Use TLS" IsChecked="True" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Nickname:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcNickBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Alt Nickname:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcAltNickBox"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Real Name:" Margin="0,0,0,2"/>
                <TextBox x:Name="IrcRealNameBox" Text="GlDrive" Margin="0,0,0,8"
                         ToolTip="Sent as the REAL NAME field during IRC registration"/>
                <TextBlock Text="Server Password (optional):" Margin="0,0,0,2"/>
                <PasswordBox x:Name="IrcPasswordBox" Margin="0,0,0,8"/>
                <TextBlock Text="Invite Nick (for SITE INVITE before joining):" Margin="0,0,0,2"/>
                <TextBox x:Name="IrcInviteNickBox" Margin="0,0,0,8"
                         ToolTip="IRC nick to pass to SITE INVITE on the FTP server before auto-joining channels"/>
                <TextBlock Text="Channels (one per line: #channel [key], prefix with - to skip auto-join):" Margin="0,0,0,2"/>
                <TextBox x:Name="IrcChannelsBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="60" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         ToolTip="e.g. #channel&#x0a;#secret mykey&#x0a;-#nochat (won't auto-join)"/>
                <CheckBox x:Name="IrcAutoConnectBox" Content="Auto-connect with server" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="IrcFishEnabledBox" Content="Enable FiSH encryption"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="IrcFishModeBox" Width="80" VerticalAlignment="Center"
                              ToolTip="ECB is standard, CBC is more secure but requires both sides to support it">
                        <ComboBoxItem Content="ECB"/>
                        <ComboBoxItem Content="CBC"/>
                    </ComboBox>
                </StackPanel>

                <Separator Margin="0,4,0,12"/>

                <!-- Spread/FXP Settings -->
                <TextBlock Text="Spread / FXP" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="Sections (Name=Path, one per line):" Margin="0,0,0,2"/>
                <TextBox x:Name="SpreadSectionsBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         ToolTip="e.g. MP3=/site/mp3&#x0a;0DAY=/site/0day"/>
                <TextBlock Text="Priority:" Margin="0,0,0,4"/>
                <ComboBox x:Name="SpreadPriorityBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8">
                    <ComboBoxItem Content="Very Low"/>
                    <ComboBoxItem Content="Low"/>
                    <ComboBoxItem Content="Normal"/>
                    <ComboBoxItem Content="High"/>
                    <ComboBoxItem Content="Very High"/>
                </ComboBox>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Max Upload Slots:" Margin="0,0,0,2"/>
                        <TextBox x:Name="SpreadMaxUpBox" Text="3" Width="60" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Max Download Slots:" Margin="0,0,0,2"/>
                        <TextBox x:Name="SpreadMaxDownBox" Text="3" Width="60" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="SpreadDownloadOnlyBox" Content="Download only (don't upload to this site)" Margin="0,0,0,8"/>
                <TextBlock Text="Affiliations (comma-separated groups):" Margin="0,0,0,2"/>
                <TextBox x:Name="SpreadAffilsBox" Margin="0,0,0,12"
                         ToolTip="Groups affiliated with this site — their releases won't be spread here"/>

                <TextBlock Text="Site Skiplist:" Margin="0,0,0,4" FontWeight="SemiBold"/>
                <DataGrid x:Name="SiteSkiplistGrid"
                          AutoGenerateColumns="False" CanUserAddRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column" Height="120" Margin="0,0,0,8">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Pattern" Binding="{Binding Pattern}" Width="*"/>
                        <DataGridCheckBoxColumn Header="Regex" Binding="{Binding IsRegex}" Width="55"/>
                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="70"/>
                        <DataGridCheckBoxColumn Header="Dirs" Binding="{Binding MatchDirectories}" Width="45"/>
                        <DataGridCheckBoxColumn Header="Files" Binding="{Binding MatchFiles}" Width="50"/>
                        <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="Add Rule" Click="AddSiteSkiplistRule_Click" Padding="12,4" Margin="0,0,6,0"/>
                    <Button Content="Remove" Click="RemoveSiteSkiplistRule_Click" Padding="12,4"/>
                </StackPanel>

                <Separator Margin="0,4,0,12"/>

                <Button Content="Test Connection" Click="TestConnection_Click"
                        HorizontalAlignment="Left" Padding="16,6"/>
                <TextBlock x:Name="TestResultText" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Click="Save_Click" Padding="20,6" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Content="Cancel" Click="Cancel_Click" Padding="20,6"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
