<Window x:Class="GlDrive.UI.ServerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Configuration" Width="520" Height="820"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Server Name:" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Margin="0,0,0,8"/>

                <TextBlock Text="Host:" Margin="0,0,0,4"/>
                <TextBox x:Name="HostBox" Margin="0,0,0,8"/>

                <TextBlock Text="Port:" Margin="0,0,0,4"/>
                <TextBox x:Name="PortBox" Text="1337" Width="100" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <TextBlock Text="Username:" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,8"/>

                <TextBlock Text="Password:" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"/>

                <TextBlock Text="Root Path:" Margin="0,0,0,4"/>
                <TextBox x:Name="RootPathBox" Text="/" Margin="0,0,0,12"/>

                <!-- SOCKS5 Proxy -->
                <Expander Header="SOCKS5 Proxy" Margin="0,0,0,8">
                    <StackPanel Margin="0,6,0,0">
                        <CheckBox x:Name="ProxyEnabledBox" Content="Connect via SOCKS5 proxy" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Proxy Host:" Margin="0,0,0,2"/>
                                <TextBox x:Name="ProxyHostBox" Margin="0,0,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Port:" Margin="0,0,0,2"/>
                                <TextBox x:Name="ProxyPortBox" Text="1080"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Proxy Username (optional):" Margin="0,0,0,2"/>
                                <TextBox x:Name="ProxyUsernameBox"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Proxy Password:" Margin="0,0,0,2"/>
                                <PasswordBox x:Name="ProxyPasswordBox"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <TextBlock Text="Drive Letter:" Margin="0,0,0,4"/>
                <ComboBox x:Name="DriveLetterBox" Width="80" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                <TextBlock Text="Volume Label:" Margin="0,0,0,4"/>
                <TextBox x:Name="VolumeLabelBox" Text="glFTPd" Margin="0,0,0,8"/>

                <CheckBox x:Name="MountDriveBox" Content="Mount as drive letter" IsChecked="True" Margin="0,8,0,4"/>
                <CheckBox x:Name="AutoMountBox" Content="Auto-connect on start" IsChecked="True" Margin="0,0,0,8"/>
                <CheckBox x:Name="PreferTls12Box" Content="Prefer TLS 1.2 (recommended for glftpd)" IsChecked="True" Margin="0,0,0,8"/>

                <TextBlock Text="Speed Limit (KB/s, 0=use global):" Margin="0,0,0,4"/>
                <TextBox x:Name="SpeedLimitBox" Text="0" Width="100" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                <!-- Cache -->
                <Expander Header="Cache" Margin="0,0,0,8">
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,4">
                            <TextBlock Text="Directory TTL (sec):" Margin="0,0,0,2"/>
                            <TextBox x:Name="CacheTtlBox" Text="30" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,4">
                            <TextBlock Text="Max Cached Dirs:" Margin="0,0,0,2"/>
                            <TextBox x:Name="MaxCachedDirsBox" Text="500" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,0">
                            <TextBlock Text="File Info Timeout (ms):" Margin="0,0,0,2"/>
                            <TextBox x:Name="FileInfoTimeoutBox" Text="1000" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- Connection Pool -->
                <Expander Header="Connection Pool" Margin="0,0,0,8">
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Max Connections:" Margin="0,0,0,2"/>
                            <TextBox x:Name="PoolSizeBox" Text="3" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Keepalive (sec):" Margin="0,0,0,2"/>
                            <TextBox x:Name="KeepaliveBox" Text="30" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </Expander>

                <!-- Notifications -->
                <Expander Header="Notifications" Margin="0,0,0,8">
                    <StackPanel Margin="0,6,0,0">
                        <CheckBox x:Name="NotificationsEnabledBox" Content="Enable new release notifications" IsChecked="True" Margin="0,0,0,8"/>
                        <TextBlock Text="Excluded Categories (comma-separated):" Margin="0,0,0,2"/>
                        <TextBox x:Name="ExcludedCategoriesBox" Margin="0,0,0,8"
                                 ToolTip="e.g. xxx-paysite, 0day — these categories won't trigger notifications"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Poll Interval (sec):" Margin="0,0,0,2"/>
                                <TextBox x:Name="PollIntervalBox" Text="60" Width="80" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Watch Path:" Margin="0,0,0,2"/>
                                <TextBox x:Name="WatchPathBox" Text="/recent" HorizontalAlignment="Left" Width="140"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>

                <!-- Search -->
                <Expander Header="Search" Margin="0,0,0,8">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Text="Search Paths (one per line):" Margin="0,0,0,2"/>
                        <TextBox x:Name="SearchPathsBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                                 Text="/" ToolTip="Directories to search for releases, e.g. /site&#x0a;/archive"/>
                        <TextBlock Text="Search Method:" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SearchMethodBox" Width="160" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="Max Depth:" Margin="0,0,0,2"/>
                                <TextBox x:Name="SearchMaxDepthBox" Text="2" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="Index Refresh (min):" Margin="0,0,0,2"/>
                                <TextBox x:Name="IndexCacheMinutesBox" Text="60" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Button Content="Discover Paths" Click="DiscoverPaths_Click"
                                        HorizontalAlignment="Left" Padding="16,6"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="DiscoverResultText" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>

                <!-- IRC Settings -->
                <Expander Header="IRC" Margin="0,0,0,8">
                 <StackPanel Margin="0,6,0,0">
                <CheckBox x:Name="IrcEnabledBox" Content="Enable IRC client" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="IRC Host:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcHostBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Port:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcPortBox" Text="6697"/>
                    </StackPanel>
                </Grid>
                <CheckBox x:Name="IrcUseTlsBox" Content="Use TLS" IsChecked="True" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Nickname:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcNickBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Alt Nickname:" Margin="0,0,0,2"/>
                        <TextBox x:Name="IrcAltNickBox"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Real Name:" Margin="0,0,0,2"/>
                <TextBox x:Name="IrcRealNameBox" Text="GlDrive" Margin="0,0,0,8"
                         ToolTip="Sent as the REAL NAME field during IRC registration"/>
                <TextBlock Text="Server Password (optional):" Margin="0,0,0,2"/>
                <PasswordBox x:Name="IrcPasswordBox" Margin="0,0,0,8"/>
                <TextBlock Text="Invite Nick (for SITE INVITE before joining):" Margin="0,0,0,2"/>
                <TextBox x:Name="IrcInviteNickBox" Margin="0,0,0,8"
                         ToolTip="IRC nick to pass to SITE INVITE on the FTP server before auto-joining channels"/>
                <TextBlock Text="Channels (one per line: #channel [key], prefix with - to skip auto-join):" Margin="0,0,0,2"/>
                <TextBox x:Name="IrcChannelsBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="60" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"
                         ToolTip="e.g. #channel&#x0a;#secret mykey&#x0a;-#nochat (won't auto-join)"/>
                <CheckBox x:Name="IrcAutoConnectBox" Content="Auto-connect with server" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox x:Name="IrcFishEnabledBox" Content="Enable FiSH encryption"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="IrcFishModeBox" Width="80" VerticalAlignment="Center"
                              ToolTip="ECB is standard, CBC is more secure but requires both sides to support it">
                        <ComboBoxItem Content="ECB"/>
                        <ComboBoxItem Content="CBC"/>
                    </ComboBox>
                </StackPanel>

                <!-- IRC Announce Rules (for auto-racing) -->
                <TextBlock Text="Announce Rules (auto-race from IRC):" Margin="0,8,0,2" FontWeight="SemiBold"/>
                <TextBlock Text="Regex with named groups: (?&lt;section&gt;...) (?&lt;release&gt;...)"
                           Foreground="{DynamicResource ForegroundDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="IrcAnnounceRulesBox" AcceptsReturn="True" TextWrapping="Wrap"
                         Height="60" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"
                         ToolTip="One rule per line: #channel pattern&#x0a;e.g. #announce (?&lt;section&gt;\w+) :: (?&lt;release&gt;\S+)&#x0a;Or: #pre \[(?&lt;section&gt;[^\]]+)\]\s*(?&lt;release&gt;\S+)"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Add Common Patterns" Click="AddCommonAnnouncePatterns_Click"
                            Padding="12,4" Margin="0,0,6,0"/>
                    <Button Content="Detect from IRC Logs" Click="DetectIrcPatterns_Click"
                            Padding="12,4"
                            ToolTip="Analyze buffered IRC messages to auto-detect announce patterns (requires IRC to be connected for a few minutes first)"/>
                </StackPanel>

                <!-- Auto Request Filler -->
                <Expander Header="Auto Request Filler (RaceTrade-style)" Margin="0,0,0,8">
                    <StackPanel Margin="0,6,0,0">
                        <CheckBox x:Name="RequestFillerEnabledBox" Content="Enable auto request filler"
                                  Margin="0,0,0,6"
                                  ToolTip="Detect !request announces on IRC and auto-fill from other connected servers"/>
                        <TextBlock Text="Request Pattern (regex with named group 'release'):" Margin="0,0,0,2"/>
                        <TextBox x:Name="RequestFillerPatternBox" Margin="0,0,0,6"
                                 ToolTip="Default: !request\s+(?&lt;release&gt;\S+)"/>
                        <TextBlock Text="Channel (empty = all):" Margin="0,0,0,2"/>
                        <TextBox x:Name="RequestFillerChannelBox" Margin="0,0,0,6"
                                 ToolTip="Only watch this channel for requests. Leave empty to watch all joined channels."/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Max Fills/Hour:" Margin="0,0,0,2"/>
                                <TextBox x:Name="RequestFillerMaxPerHourBox" Text="10" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Cooldown (sec):" Margin="0,0,0,2"/>
                                <TextBox x:Name="RequestFillerCooldownBox" Text="60" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Expander>
                 </StackPanel>
                </Expander>

                <!-- Spread/FXP Settings -->
                <Expander Header="Spread / FXP" Margin="0,0,0,8" IsExpanded="True">
                    <StackPanel Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="AI Setup" Click="AiSetup_Click"
                                    Padding="12,4" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}"
                                    ToolTip="Use AI (OpenRouter) to analyze SITE RULES and suggest optimal spread configuration"/>
                            <Button Content="Quick Setup" Click="QuickSetup_Click"
                                    Padding="12,4" Style="{StaticResource PrimaryButton}"
                                    ToolTip="Auto-detect sections, site rules, skiplist, and slots — all in one click"/>
                        </StackPanel>

                        <!-- Unified Section Mappings (replaces old SpreadSectionsBox) -->
                        <DockPanel Margin="0,0,0,2">
                            <Button DockPanel.Dock="Right" Content="Auto-Detect" Click="AutoDetectSections_Click"
                                    Padding="8,2" Margin="6,0,0,0" VerticalAlignment="Bottom"/>
                            <CheckBox x:Name="ScanAllDirsBox" DockPanel.Dock="Right" Content="Scan all"
                                      VerticalAlignment="Bottom" Margin="0,0,6,0"
                                      ToolTip="Scan all directories, not just /incoming/"/>
                            <TextBlock Text="Sections &amp; IRC Mappings:" VerticalAlignment="Bottom" FontWeight="SemiBold"/>
                        </DockPanel>
                        <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundDimBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,4"
                                   Text="Each row is one section on this server. IRC Section = name announced on IRC; Remote Section = internal key used by spread; Path = directory on the server. Trigger regex filters which announces use this mapping (default .*). Tag Rules are per-mapping filters."/>
                        <DataGrid x:Name="SectionMappingsGrid"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" Height="140" Margin="0,0,0,6">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="35"/>
                                <DataGridTextColumn Header="IRC Section" Binding="{Binding IrcSection}" Width="100"/>
                                <DataGridTextColumn Header="Remote Section" Binding="{Binding RemoteSection}" Width="110"/>
                                <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                                <DataGridTextColumn Header="Trigger" Binding="{Binding TriggerRegex}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Add" Click="AddSectionMapping_Click" Padding="12,4" Margin="0,0,6,0"/>
                            <Button Content="Remove" Click="RemoveSectionMapping_Click" Padding="12,4" Margin="0,0,6,0"/>
                            <Button Content="Edit Tag Rules..." Click="EditTagRules_Click" Padding="12,4"
                                    ToolTip="Per-mapping tag rules (DENY/ALLOW) applied only to this mapping"/>
                        </StackPanel>

                        <TextBlock Text="Priority:" Margin="0,0,0,4"/>
                        <ComboBox x:Name="SpreadPriorityBox" Width="120" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <ComboBoxItem Content="Very Low"/>
                            <ComboBoxItem Content="Low"/>
                            <ComboBoxItem Content="Normal"/>
                            <ComboBoxItem Content="High"/>
                            <ComboBoxItem Content="Very High"/>
                        </ComboBox>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Max Upload Slots:" Margin="0,0,0,2"/>
                                <TextBox x:Name="SpreadMaxUpBox" Text="3" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Max Download Slots:" Margin="0,0,0,2"/>
                                <TextBox x:Name="SpreadMaxDownBox" Text="3" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <CheckBox x:Name="SpreadDownloadOnlyBox" Content="Download only (don't upload to this site)" Margin="0,0,0,8"/>
                        <TextBlock Text="Affiliations (comma-separated groups):" Margin="0,0,0,2"/>
                        <TextBox x:Name="SpreadAffilsBox" Margin="0,0,0,4"
                                 ToolTip="Groups affiliated with this site — their releases get auto-allowed (highest priority in rules engine)"/>
                    </StackPanel>
                </Expander>

                <!-- Site Skiplist -->
                <Expander Header="Site Skiplist" Margin="0,0,0,8">
                    <StackPanel Margin="0,6,0,0">
                        <DataGrid x:Name="SiteSkiplistGrid"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" Height="140" Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Pattern" Binding="{Binding Pattern}" Width="140"/>
                                <DataGridCheckBoxColumn Header="Rx" Binding="{Binding IsRegex}" Width="40"/>
                                <DataGridTextColumn Header="Expression" Binding="{Binding Expression}" Width="*"/>
                                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="65"/>
                                <DataGridCheckBoxColumn Header="Dirs" Binding="{Binding MatchDirectories}" Width="40"/>
                                <DataGridCheckBoxColumn Header="Files" Binding="{Binding MatchFiles}" Width="45"/>
                                <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="Add Rule" Click="AddSiteSkiplistRule_Click" Padding="12,4" Margin="0,0,6,0"/>
                            <Button Content="Remove" Click="RemoveSiteSkiplistRule_Click" Padding="12,4" Margin="0,0,6,0"/>
                            <Button Content="Add Defaults" Click="AddDefaultSkiplistRules_Click" Padding="12,4"
                                    ToolTip="Add common scene skiplist rules (incomplete, sample, proof, etc.)"/>
                            <Button Content="Import..." Click="ImportSiteSkiplist_Click" Padding="12,4" Margin="6,0,0,0"/>
                            <Button Content="Detect Rules" Click="DetectSiteRules_Click" Padding="12,4" Margin="6,0,0,0"
                                    ToolTip="Run SITE RULES on the server and auto-configure slots, skiplist, and affils"/>
                        </StackPanel>
                        <Button Content="Test Rules..." Click="TestRules_Click" Padding="12,4"
                                HorizontalAlignment="Left"
                                Style="{StaticResource SecondaryButton}"
                                ToolTip="Test how current rules evaluate against a sample release name"/>
                    </StackPanel>
                </Expander>

                <!-- Metadata Filter (IMDb/TVMaze) -->
                <Expander Header="Metadata Filter (IMDb/TVMaze — no API key required)" Margin="0,0,0,8">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundDimBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="Filters releases by IMDb rating (movies via imdbapi.dev free fallback) and TVMaze data (TV). Fails OPEN on lookup error so flaky APIs don't block races."/>
                        <CheckBox x:Name="MetaFilterEnabledBox" Content="Enable metadata filter for auto-race"
                                  Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Min IMDb Rating:" Margin="0,0,0,2"/>
                                <TextBox x:Name="MetaMinRatingBox" Text="0" Width="60" HorizontalAlignment="Left"
                                         ToolTip="0-10. 0 = no threshold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Min Votes:" Margin="0,0,0,2"/>
                                <TextBox x:Name="MetaMinVotesBox" Text="0" Width="60" HorizontalAlignment="Left"
                                         ToolTip="0 = no threshold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Timeout (sec):" Margin="0,0,0,2"/>
                                <TextBox x:Name="MetaTimeoutBox" Text="5" Width="60" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Allow Genres (comma-separated, empty = all):" Margin="0,0,0,2"/>
                        <TextBox x:Name="MetaAllowGenresBox" Margin="0,0,0,6"
                                 ToolTip="e.g. Action, Drama, Sci-Fi"/>
                        <TextBlock Text="Deny Genres (takes precedence over allow):" Margin="0,0,0,2"/>
                        <TextBox x:Name="MetaDenyGenresBox" Margin="0,0,0,6"
                                 ToolTip="e.g. Documentary, Reality-TV"/>
                        <CheckBox x:Name="MetaSkipEndedBox" Content="Skip ended/cancelled TV shows"
                                  Margin="0,0,0,4"/>
                    </StackPanel>
                </Expander>

                <Separator Margin="0,4,0,12"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Test Connection" Click="TestConnection_Click"
                            Padding="16,6" Margin="0,0,8,0"/>
                    <Button Content="Clear Certificate" Click="ClearCert_Click"
                            Padding="16,6" ToolTip="Remove the trusted TLS certificate for this server (will be re-accepted on next connect)"/>
                </StackPanel>
                <TextBlock x:Name="TestResultText" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Click="Save_Click" Padding="20,6" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButton}"/>
            <Button Content="Cancel" Click="Cancel_Click" Padding="20,6"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
