<Window x:Class="GlDrive.UI.RuleTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Test Rules" Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
        <DockPanel>
            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                <TextBlock Text="&gt;&gt; RULE TEST" Style="{DynamicResource SectionHeaderTextStyle}"/>
            </Border>
            <Grid Margin="12">
                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Release Name:" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="1" x:Name="ReleaseBox" Margin="0,0,0,8"
                             Text="Some.Movie.2024.1080p.BluRay.x264-GROUP"/>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="IRC Section (for mapping lookup):" Margin="0,0,0,2"/>
                            <TextBox x:Name="SectionBox" Text="TV-1080P"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Evaluate" Click="Evaluate_Click"
                                Padding="20,6" VerticalAlignment="Bottom"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>

                    <TextBox Grid.Row="3" x:Name="ResultBox" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             Background="{DynamicResource SurfaceBrush}"/>

                    <Button Grid.Row="4" Content="Close" Click="Close_Click"
                            HorizontalAlignment="Right" Padding="20,6" Margin="0,12,0,0"
                            Style="{StaticResource SecondaryButton}"/>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
