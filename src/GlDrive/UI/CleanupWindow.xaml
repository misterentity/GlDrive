<Window x:Class="GlDrive.UI.CleanupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folder Cleaner" Width="700" Height="500"
        MinWidth="500" MinHeight="350"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <Button x:Name="ScanButton" DockPanel.Dock="Right" Content="Scan" Click="Scan_Click"
                    Padding="16,5" Style="{StaticResource PrimaryButton}" FontSize="11"/>
            <Button DockPanel.Dock="Right" Content="..." Click="Browse_Click"
                    Padding="8,5" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
            <TextBlock Text="Folder:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                       Foreground="{DynamicResource ForegroundDimBrush}"/>
            <TextBox x:Name="ScanPath" FontSize="11" Padding="4,4"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource ForegroundBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"/>
        </DockPanel>

        <!-- Results grid -->
        <DataGrid Grid.Row="1" x:Name="ResultsGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceLightBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Folder" Binding="{Binding FolderName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Archives" Binding="{Binding ArchiveCount}" Width="65"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="80"/>
                <DataGridTextColumn Header="Media" Binding="{Binding MediaCount}" Width="55"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="4,2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Cleaned">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                    <Setter Property="Foreground" Value="#F44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Scan hint -->
        <TextBlock Grid.Row="1" x:Name="ScanHint"
                   Text="Select a folder and click Scan to find leftover archives"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="14" Foreground="{DynamicResource ForegroundDimBrush}"
                   IsHitTestVisible="False"/>

        <!-- Summary -->
        <TextBlock Grid.Row="2" x:Name="SummaryText" FontSize="11" Margin="0,8,0,0"
                   Foreground="{DynamicResource ForegroundDimBrush}"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="CleanSelectedButton" Content="Clean Selected" Click="CleanSelected_Click"
                    Padding="16,5" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}"
                    FontSize="11" IsEnabled="False"/>
            <Button x:Name="CleanAllButton" Content="Clean All" Click="CleanAll_Click"
                    Padding="16,5" Style="{StaticResource PrimaryButton}"
                    FontSize="11" FontWeight="SemiBold" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
