<Window x:Class="GlDrive.UI.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:GlDrive.UI"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="GlDrive Dashboard" Width="1860" Height="1000"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <ui:ImageUrlConverter x:Key="ImageUrlConverter"/>
        <Style x:Key="ModeTabStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}" Cursor="Hand"
                                BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SurfaceLightBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ForegroundDimBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentDimBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ForegroundBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- ============================================================== -->
        <!-- TOP BAR (cyberpunk shell chrome)                                -->
        <!-- ============================================================== -->
        <Border Grid.Row="0" Background="{DynamicResource TopBarBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo block -->
                <Border Grid.Column="0" Background="{DynamicResource TopBarLogoBrush}"
                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,1,0"
                        Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="22" Height="22" Margin="0,0,10,0">
                            <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                  Effect="{DynamicResource SignatureGlowEffect}"
                                  Data="M 2,12 L 12,2 L 22,12 L 12,22 Z"/>
                            <Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="1"
                                  Fill="#6600E5FF"
                                  Data="M 7,12 L 12,7 L 17,12 L 12,17 Z"/>
                            <Ellipse Width="3" Height="3" Fill="{DynamicResource Signature2Brush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="GLDRIVE" Style="{DynamicResource DisplayTextGlowStyle}"
                                       FontSize="16" Foreground="{DynamicResource AccentBrush}"
                                       LineHeight="14"/>
                            <TextBlock Text="{Binding VersionTagline}" Style="{DynamicResource MicroTextStyle}"
                                       FontSize="9" Foreground="{DynamicResource TextFaintBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Breadcrumb + status tags -->
                <Grid Grid.Column="1" Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="NODE:" Style="{DynamicResource MicroTextStyle}"
                               Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <Border Grid.Column="1" BorderBrush="{DynamicResource LineDimBrush}" BorderThickness="1"
                            Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="CRADLE.GLFTPD" Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"/>
                    </Border>
                    <TextBlock Grid.Column="2" Text="SECT/" Style="{DynamicResource MicroTextStyle}"
                               Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"
                               Margin="14,0,8,0"/>
                    <TextBlock Grid.Column="3" Style="{DynamicResource DisplayTextStyle}"
                               FontSize="14" Foreground="{DynamicResource ForegroundBrush}"
                               VerticalAlignment="Center"
                               Text="DASHBOARD"/>

                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <Border Style="{DynamicResource TagGoodStyle}" Padding="7,2" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{DynamicResource GoodBrush}"
                                         VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="TLS 1.2 // PROT P" Style="{DynamicResource TagTextStyle}"
                                           Foreground="{DynamicResource GoodBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{DynamicResource TagAccentStyle}" Padding="7,2">
                            <TextBlock Text="FXP RELAY ACTIVE" Style="{DynamicResource TagTextStyle}"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Clock + window-control glyphs -->
                <Border Grid.Column="2" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1,0,0,0"
                        Padding="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="UtcClockText" Text="--:--:-- UTC" Style="{DynamicResource AccentTextStyle}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0"
                                   FontFamily="{DynamicResource MonoFontFamily}"/>
                        <Rectangle Width="10" Height="10" Stroke="{DynamicResource TextFaintBrush}"
                                   StrokeThickness="1" Margin="0,0,5,0"/>
                        <Rectangle Width="10" Height="10" Stroke="{DynamicResource TextFaintBrush}"
                                   StrokeThickness="1" Margin="0,0,5,0"/>
                        <Rectangle Width="10" Height="10" Stroke="{DynamicResource BadBrush}"
                                   StrokeThickness="1"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="1" Padding="0">

            <!-- ===== DASHBOARD group ===== -->
            <TabItem IsEnabled="False" Focusable="False" IsHitTestVisible="False" Padding="14,12,14,4">
                <TabItem.Header>
                    <TextBlock Text="&#x25B8; DASHBOARD" FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="9" Foreground="{DynamicResource TextFaintBrush}" Margin="0,8,0,0"/>
                </TabItem.Header>
            </TabItem>

            <!-- Overview Tab -->
            <TabItem x:Name="OverviewTab">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="01" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Overview" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <DockPanel Margin="12">
                    <!-- Stat cards row -->
                    <Border DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="SERVERS" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding MountedServerCount}" Style="{DynamicResource StatCardValueStyle}"/>
                                            <TextBlock Text="/" Style="{DynamicResource StatCardValueStyle}" Foreground="{DynamicResource TextFaintBrush}" Margin="6,0"/>
                                            <TextBlock Text="{Binding ConfiguredServerCount}" Style="{DynamicResource StatCardValueStyle}" Foreground="{DynamicResource TextDimBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="ACTIVE DL" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding ActiveDownloadCount, FallbackValue=0}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="QUEUED" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding QueuedDownloadCount, FallbackValue=0}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="DONE TODAY" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding CompletedTodayCount, FallbackValue=0}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Main 2x2 body: volumes (TL), throughput (TR), telemetry (BL), ops log (BR) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3*"/>
                            <RowDefinition Height="2*"/>
                        </Grid.RowDefinitions>

                        <!-- Top-left: Mounted Volumes -->
                        <Border Grid.Row="0" Grid.Column="0" Style="{DynamicResource HudPanelStyle}" Margin="0,0,6,6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                    <TextBlock Text="&gt;&gt; MOUNTED VOLUMES" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                </Border>
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding MountedServerStatus}" Margin="14">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#80050F1A" BorderBrush="{DynamicResource LineBrush}"
                                                            BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Large filled-arc capacity disc -->
                                                            <Grid Grid.Column="0" Width="86" Height="86" VerticalAlignment="Center">
                                                                <Ellipse Width="86" Height="86" Stroke="{DynamicResource LineDimBrush}" StrokeThickness="2"/>
                                                                <Ellipse Width="86" Height="86" Stroke="{DynamicResource AccentBrush}" StrokeThickness="3"
                                                                         StrokeDashArray="2,1" RenderTransformOrigin="0.5,0.5">
                                                                    <Ellipse.Effect>
                                                                        <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                                                    </Ellipse.Effect>
                                                                    <Ellipse.RenderTransform>
                                                                        <RotateTransform Angle="0"/>
                                                                    </Ellipse.RenderTransform>
                                                                    <Ellipse.Triggers>
                                                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                                     From="0" To="360" Duration="0:0:14" RepeatBehavior="Forever"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Ellipse.Triggers>
                                                                </Ellipse>
                                                                <Ellipse Width="64" Height="64" Stroke="{DynamicResource LineDimBrush}" StrokeThickness="1"/>
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding CapacityPercent, StringFormat=N0}" Style="{DynamicResource DisplayTextStyle}"
                                                                                   HorizontalAlignment="Center" FontSize="20"/>
                                                                        <TextBlock Text="%" Style="{DynamicResource DisplayTextStyle}" FontSize="14" VerticalAlignment="Bottom" Margin="2,0,0,3"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="POOL" Style="{DynamicResource MicroTextStyle}" HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Grid>
                                                            <DockPanel Grid.Column="1" Margin="16,0,0,0" LastChildFill="True">
                                                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Name}" Style="{DynamicResource DisplayTextStyle}" FontSize="15"/>
                                                                    <Border Margin="10,0,0,0" Style="{DynamicResource ServerStatusTagStyle}" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding SiteTag}" Style="{DynamicResource ServerStatusTextStyle}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock DockPanel.Dock="Top" Text="{Binding Host}" Style="{DynamicResource MicroTextStyle}" Margin="0,2,0,8"/>
                                                                <Border DockPanel.Dock="Top" Height="6" Background="{DynamicResource Background3Brush}" Margin="0,0,0,6">
                                                                    <Border HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}"
                                                                            Width="{Binding CapacityPercent}">
                                                                        <Border.Effect>
                                                                            <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                                                        </Border.Effect>
                                                                    </Border>
                                                                </Border>
                                                                <Grid DockPanel.Dock="Top">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" FontFamily="{DynamicResource MonoFontFamily}" FontSize="11">
                                                                        <Run Text="{Binding CapacityUsedDisplay}" Foreground="{DynamicResource ForegroundBrush}"/>
                                                                        <Run Text=" / " Foreground="{DynamicResource TextFaintBrush}"/>
                                                                        <Run Text="{Binding CapacityTotalDisplay}" Foreground="{DynamicResource TextDimBrush}"/>
                                                                    </TextBlock>
                                                                    <Border Grid.Column="1" Style="{DynamicResource TagStyle}">
                                                                        <TextBlock Text="{Binding StatusLine}" Style="{DynamicResource TagTextStyle}"/>
                                                                    </Border>
                                                                </Grid>
                                                            </DockPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- Top-right: Throughput -->
                        <Border Grid.Row="0" Grid.Column="1" Style="{DynamicResource HudPanelStyle}" Margin="6,0,0,6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                    <TextBlock Text="&gt;&gt; THROUGHPUT" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                </Border>
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <DockPanel Margin="14">
                                        <!-- Rx / Tx numbers -->
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="RX" Style="{DynamicResource MicroTextStyle}"/>
                                                <TextBlock Text="{Binding RxRateDisplay}" Style="{DynamicResource DisplayTextStyle}"
                                                           FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="TX" Style="{DynamicResource MicroTextStyle}"/>
                                                <TextBlock Text="{Binding TxRateDisplay}" Style="{DynamicResource DisplayTextStyle}"
                                                           FontSize="24" Foreground="{DynamicResource Signature2Brush}"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Area chart -->
                                        <Border Height="120" Background="#80050F1A" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                                            <Border.Resources>
                                                <DrawingBrush x:Key="ChartGridBrush" TileMode="Tile" Stretch="None"
                                                              Viewport="0,0,24,12" ViewportUnits="Absolute">
                                                    <DrawingBrush.Drawing>
                                                        <DrawingGroup>
                                                            <GeometryDrawing>
                                                                <GeometryDrawing.Pen>
                                                                    <Pen Brush="{DynamicResource LineDimBrush}" Thickness="1"/>
                                                                </GeometryDrawing.Pen>
                                                                <GeometryDrawing.Geometry>
                                                                    <GeometryGroup>
                                                                        <LineGeometry StartPoint="0,0" EndPoint="24,0"/>
                                                                        <LineGeometry StartPoint="0,0" EndPoint="0,12"/>
                                                                    </GeometryGroup>
                                                                </GeometryDrawing.Geometry>
                                                            </GeometryDrawing>
                                                        </DrawingGroup>
                                                    </DrawingBrush.Drawing>
                                                </DrawingBrush>
                                            </Border.Resources>
                                            <Grid>
                                                <Rectangle Fill="{StaticResource ChartGridBrush}" Opacity="0.6"/>
                                                <Polyline Points="{Binding ThroughputPoints}"
                                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.6"
                                                          Stretch="Fill">
                                                    <Polyline.Effect>
                                                        <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                                    </Polyline.Effect>
                                                </Polyline>
                                            </Grid>
                                        </Border>
                                    </DockPanel>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- Bottom-left: Kernel Telemetry -->
                        <Border Grid.Row="1" Grid.Column="0" Style="{DynamicResource HudPanelStyle}" Margin="0,6,6,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                    <TextBlock Text="&gt;&gt; KERNEL TELEMETRY" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                </Border>
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="14">
                                        <!-- CPU row -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="CPU" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Height="8" Background="{DynamicResource Background3Brush}" VerticalAlignment="Center">
                                                <Border HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}"
                                                        Width="{Binding TelemetryCpuPercent}">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                                    </Border.Effect>
                                                </Border>
                                            </Border>
                                            <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="11"
                                                       Foreground="{DynamicResource ForegroundBrush}">
                                                <Run Text="{Binding TelemetryCpuPercent, StringFormat=N0}"/><Run Text="%"/>
                                            </TextBlock>
                                        </Grid>
                                        <!-- MEM row (text only) -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="MEM" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="11"
                                                       Foreground="{DynamicResource ForegroundBrush}">
                                                <Run Text="{Binding TelemetryMemoryMb, StringFormat=N0}"/><Run Text=" MB"/>
                                            </TextBlock>
                                        </Grid>
                                        <!-- POOL row -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="POOL" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                                            <Border Grid.Column="1" Height="8" Background="{DynamicResource Background3Brush}" VerticalAlignment="Center">
                                                <Border HorizontalAlignment="Left" Background="{DynamicResource Signature2Brush}"
                                                        Width="{Binding TelemetryPoolUtilization}">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#FF2AB8" BlurRadius="6" ShadowDepth="0" Opacity="0.6"/>
                                                    </Border.Effect>
                                                </Border>
                                            </Border>
                                            <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="11"
                                                       Foreground="{DynamicResource ForegroundBrush}">
                                                <Run Text="{Binding TelemetryPoolUtilization, StringFormat=N0}"/><Run Text="%"/>
                                            </TextBlock>
                                        </Grid>
                                        <!-- Uptime + threads -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="UPTIME" Style="{DynamicResource MicroTextStyle}"/>
                                                <TextBlock Text="{Binding TelemetryUptime}"
                                                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="THREADS" Style="{DynamicResource MicroTextStyle}"/>
                                                <TextBlock Text="{Binding TelemetryThreadCount}"
                                                           FontFamily="{DynamicResource MonoFontFamily}" FontSize="12"
                                                           Foreground="{DynamicResource ForegroundBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <!-- Bottom-right: Operations Log -->
                        <Border Grid.Row="1" Grid.Column="1" Style="{DynamicResource HudPanelStyle}" Margin="6,6,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                    <TextBlock Text="&gt;&gt; OPERATIONS LOG" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                </Border>
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding OperationsLogPreview}"
                                                   FontFamily="{DynamicResource MonoFontFamily}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   TextWrapping="NoWrap"
                                                   Margin="14"/>
                                    </ScrollViewer>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- Notifications Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="02" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Notifications" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <DockPanel Margin="12">
                    <!-- Toolbar (preserved as-is) -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6" Padding="8,6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Download" Command="{Binding DownloadNotificationCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Race" Command="{Binding RaceNotificationCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource PrimaryButton}"
                                    ToolTip="Start FXP race for selected release across all configured servers"/>
                            <Button Content="Clear All" Command="{Binding ClearNotificationsCommand}"
                                    Padding="12,6" Margin="0,0,12,0" Style="{StaticResource SecondaryButton}"/>
                            <TextBox Text="{Binding NotificationFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="160" VerticalContentAlignment="Center" Margin="0,0,6,0"
                                     ToolTip="Filter by release name"/>
                            <ComboBox ItemsSource="{Binding NotificationCategories}"
                                      SelectedItem="{Binding NotificationFilterCategory}"
                                      Width="110" Margin="0,0,6,0" ToolTip="Filter by category"/>
                            <ComboBox ItemsSource="{Binding NotificationServers}"
                                      SelectedItem="{Binding NotificationFilterServer}"
                                      Width="110" ToolTip="Filter by server"/>
                        </StackPanel>
                    </Border>
                    <!-- DETAIL HUD panel -->
                    <Border DockPanel.Dock="Bottom" Height="180" Margin="0,10,0,0"
                            Style="{DynamicResource HudPanelStyle}"
                            Visibility="{Binding HasNotificationSelection, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; DETAIL" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <DockPanel Margin="14">
                                    <Border DockPanel.Dock="Left" Width="95" Margin="0,0,16,0"
                                            CornerRadius="4" ClipToBounds="True"
                                            Background="{DynamicResource SurfaceLightBrush}"
                                            Visibility="{Binding HasNotificationPoster, Converter={StaticResource BoolToVisibility}}">
                                        <Image Stretch="UniformToFill" VerticalAlignment="Top"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="{Binding NotificationPosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=120}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Top">
                                        <TextBlock FontWeight="Bold" FontSize="16"
                                                   Foreground="White"
                                                   Text="{Binding SelectedNotificationItem.ReleaseName}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding NotificationRating}" FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="{Binding NotificationGenres}" FontSize="12.5"
                                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                                       Margin="14,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding NotificationPlot}" TextWrapping="Wrap"
                                                   MaxHeight="65" FontSize="12.5" Margin="0,8,0,0"
                                                   LineHeight="18"
                                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                    <!-- NEW RELEASE FEED HUD panel wrapping the DataGrid -->
                    <Border Style="{DynamicResource HudPanelStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; NEW RELEASE FEED" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <DataGrid ItemsSource="{Binding NotificationItems}"
                                          SelectedItem="{Binding SelectedNotificationItem}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column" CanUserAddRows="False"
                                          Background="Transparent" BorderThickness="0"
                                          x:Name="NotificationsGrid"
                                          PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                                          MouseMove="DragSource_MouseMove">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Download" Command="{Binding DownloadNotificationCommand}" FontWeight="Bold"/>
                                            <MenuItem Header="Race / Spread" Command="{Binding RaceNotificationCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Search on Servers" Command="{Binding SearchNotificationOnServersCommand}"/>
                                            <MenuItem Header="Copy Release Name" Command="{Binding CopyNotificationReleaseCommand}"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding DownloadNotificationCommand}"/>
                                    </DataGrid.InputBindings>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding TimeDisplay}" Width="130"/>
                                        <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" Width="90"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                                        <DataGridTextColumn Header="Release" Binding="{Binding ReleaseName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- Wishlist Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="03" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Wishlist" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                            <TextBlock Text="&gt;&gt; WISHLIST" Style="{DynamicResource SectionHeaderTextStyle}"/>
                        </Border>
                        <Grid>
                            <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                            <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6" Padding="8,6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Movie" Command="{Binding AddMovieCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="+ TV Show" Command="{Binding AddTvShowCommand}"
                                    Padding="12,6" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Remove" Command="{Binding RemoveWishlistCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Pause" Command="{Binding TogglePauseCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Refresh Info" Command="{Binding RefreshMetadataCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}"
                                    ToolTip="Fetch posters, ratings, and plots for all items"/>
                            <Button Content="Export" Command="{Binding ExportWishlistCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource SecondaryButton}"/>
                            <Button Content="Import" Command="{Binding ImportWishlistCommand}"
                                    Padding="12,6" Style="{StaticResource SecondaryButton}"/>
                        </StackPanel>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Height="155"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Margin="0,10,0,0" Padding="14"
                            Visibility="{Binding HasWishlistSelection, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Left" Width="95" Margin="0,0,16,0"
                                    CornerRadius="4" ClipToBounds="True"
                                    Background="{DynamicResource SurfaceLightBrush}"
                                    Visibility="{Binding HasSelectedPoster, Converter={StaticResource BoolToVisibility}}">
                                <Image Stretch="UniformToFill" VerticalAlignment="Top"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="{Binding SelectedPosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=120}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock FontWeight="Bold" FontSize="16" Foreground="White">
                                    <Run Text="{Binding SelectedWishlistItem.Title, Mode=OneWay}"/>
                                    <Run Text=" ("/>
                                    <Run Text="{Binding SelectedWishlistItem.Year, Mode=OneWay}"/>
                                    <Run Text=")"/>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding SelectedRating}" FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="{Binding SelectedGenres}" FontSize="12.5"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               Margin="14,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedPlot}" TextWrapping="Wrap"
                                           MaxHeight="65" FontSize="12.5" Margin="0,8,0,0"
                                           LineHeight="18"
                                           Foreground="{DynamicResource ForegroundDimBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <DataGrid ItemsSource="{Binding WishlistItems}"
                              SelectedItem="{Binding SelectedWishlistItem}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                            <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="60"/>
                            <DataGridTextColumn Header="Quality" Binding="{Binding Quality}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                            <DataGridTextColumn Header="Grabbed" Binding="{Binding GrabbedCount}" Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- Downloads Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="04" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Downloads" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <DockPanel Margin="12">
                    <!-- Stats cards row -->
                    <Border DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="ACTIVE" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding ActiveDownloadCount, FallbackValue=—}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="QUEUED" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding QueuedDownloadCount, FallbackValue=—}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="ERRORS" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding FailedDownloadCount, FallbackValue=—}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="TODAY" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding CompletedTodayCount, FallbackValue=—}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="10,6"
                            Background="{DynamicResource SurfaceBrush}" CornerRadius="4"
                            Visibility="{Binding HasActiveDownload, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ActiveDownloadSummary}" FontSize="12"
                                   Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap"/>
                    </Border>
                    <Border DockPanel.Dock="Top" Height="56" Margin="0,0,0,6"
                            Background="{DynamicResource Background1Brush}"
                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                            ClipToBounds="True"
                            Visibility="{Binding HasActiveDownload, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Rectangle>
                                <Rectangle.Fill>
                                    <DrawingBrush TileMode="Tile" Viewport="0,0,24,12" ViewportUnits="Absolute" Stretch="None">
                                        <DrawingBrush.Drawing>
                                            <DrawingGroup>
                                                <GeometryDrawing>
                                                    <GeometryDrawing.Pen>
                                                        <Pen Brush="#1C4368" Thickness="1"/>
                                                    </GeometryDrawing.Pen>
                                                    <GeometryDrawing.Geometry>
                                                        <GeometryGroup>
                                                            <LineGeometry StartPoint="24,0" EndPoint="24,12"/>
                                                            <LineGeometry StartPoint="0,12" EndPoint="24,12"/>
                                                        </GeometryGroup>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Polyline Points="{Binding SpeedGraphPoints}" Stroke="{DynamicResource AccentBrush}"
                                      StrokeThickness="1.6" StrokeLineJoin="Round">
                                <Polyline.Effect>
                                    <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.85"/>
                                </Polyline.Effect>
                            </Polyline>
                        </Grid>
                    </Border>
                    <!-- Transfer Queue HUD panel wrapping the toolbar + DataGrid -->
                    <Border Style="{DynamicResource HudPanelStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; TRANSFER QUEUE" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="6" Padding="8,6" Margin="0,0,0,0">
                                        <WrapPanel>
                                            <Button Content="Cancel" Command="{Binding CancelDownloadCommand}"
                                                    Padding="12,6" Margin="0,0,6,4" Style="{StaticResource SecondaryButton}"/>
                                            <Button Content="Retry" Command="{Binding RetryDownloadCommand}"
                                                    Padding="12,6" Margin="0,0,6,4" Style="{StaticResource SecondaryButton}"/>
                                            <Button Content="Open Folder" Command="{Binding OpenFolderCommand}"
                                                    Padding="12,6" Margin="0,0,12,4" Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Open download folder in Explorer"/>
                                            <Button Content="Clear Completed" Command="{Binding ClearCompletedCommand}"
                                                    Padding="12,6" Margin="0,0,6,4" Style="{StaticResource SecondaryButton}"/>
                                            <Button Content="Clear Failed" Command="{Binding ClearFailedCommand}"
                                                    Padding="12,6" Margin="0,0,6,4" Style="{StaticResource SecondaryButton}"/>
                                            <Button Content="Clear Cancelled" Command="{Binding ClearCancelledCommand}"
                                                    Padding="12,6" Margin="0,0,6,4" Style="{StaticResource SecondaryButton}"/>
                                            <Button Content="Clear All Finished" Command="{Binding ClearAllFinishedCommand}"
                                                    Padding="12,6" Margin="0,0,12,4" Style="{StaticResource SecondaryButton}"
                                                    ToolTip="Clear completed, failed, and cancelled"/>
                                            <Button Content="Move Up" Command="{Binding MoveUpCommand}"
                                                    Padding="12,6" Margin="0,0,6,4" Style="{StaticResource SecondaryButton}"/>
                                            <Button Content="Move Down" Command="{Binding MoveDownCommand}"
                                                    Padding="12,6" Margin="0,0,0,4" Style="{StaticResource SecondaryButton}"/>
                                        </WrapPanel>
                                    </Border>
                                    <ListBox ItemsSource="{Binding DownloadItems}"
                              SelectedItem="{Binding SelectedDownloadItem}"
                              SelectionMode="Extended"
                              AllowDrop="True" Drop="Downloads_Drop"
                              x:Name="DownloadsGrid"
                              SelectionChanged="DownloadsGrid_SelectionChanged"
                              Background="Transparent" BorderThickness="0"
                              HorizontalContentAlignment="Stretch"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Cancel" Command="{Binding CancelDownloadCommand}"/>
                                <MenuItem Header="Retry" Command="{Binding RetryDownloadCommand}"/>
                                <MenuItem Header="Open Folder" Command="{Binding OpenFolderCommand}"/>
                                <Separator/>
                                <MenuItem Header="Remove Selected" Command="{Binding RemoveSelectedDownloadsCommand}"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding RemoveSelectedDownloadsCommand}"/>
                            <KeyBinding Key="R" Command="{Binding RetryDownloadCommand}"/>
                        </ListBox.InputBindings>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="14,10"
                                        Background="#80050F1A"
                                        BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Top row: release name + status chip -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding ReleaseName}"
                                                   Style="{DynamicResource DisplayTextStyle}" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Row="0" Grid.Column="3"
                                                Style="{DynamicResource DownloadStatusTagStyle}"
                                                HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Status}" Style="{DynamicResource DownloadStatusTextStyle}"/>
                                        </Border>

                                        <!-- Middle row: server / category / speed micro-text -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,4,0,8">
                                            <TextBlock Text="{Binding ServerName}" Style="{DynamicResource AccentTextStyle}" FontSize="11"/>
                                            <TextBlock Text=" · " Foreground="{DynamicResource TextFaintBrush}"/>
                                            <TextBlock Text="{Binding Category}" Style="{DynamicResource MicroTextStyle}"/>
                                            <TextBlock Text=" · " Foreground="{DynamicResource TextFaintBrush}"/>
                                            <TextBlock Text="{Binding ProgressText}" Style="{DynamicResource MicroTextStyle}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding SpeedDisplay}"
                                                   HorizontalAlignment="Right"
                                                   Style="{DynamicResource AccentTextStyle}" FontSize="11"/>

                                        <!-- Progress bar -->
                                        <ProgressBar Grid.Row="2" Grid.ColumnSpan="4" Height="5"
                                                     Minimum="0" Maximum="100"
                                                     Value="{Binding ProgressPercent, FallbackValue=0}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ===== MEDIA group ===== -->
            <TabItem IsEnabled="False" Focusable="False" IsHitTestVisible="False" Padding="14,12,14,4">
                <TabItem.Header>
                    <TextBlock Text="&#x25B8; MEDIA" FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="9" Foreground="{DynamicResource TextFaintBrush}" Margin="0,8,0,0"/>
                </TabItem.Header>
            </TabItem>

            <!-- Search Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="05" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Search" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                            <TextBlock Text="&gt;&gt; SEARCH" Style="{DynamicResource SectionHeaderTextStyle}"/>
                        </Border>
                        <Grid>
                            <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                            <DockPanel Margin="12">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding CancelSearchCommand}"
                                Padding="12,6" Margin="6,0,0,0" Style="{StaticResource SecondaryButton}"
                                Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibility}}"/>
                        <Button DockPanel.Dock="Right" Content="Search" Command="{Binding SearchCommand}"
                                Padding="18,6" Margin="10,0,0,0" Style="{StaticResource PrimaryButton}"/>
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding SearchStatus}" Margin="0,0,0,6"
                               Foreground="{DynamicResource ForegroundDimBrush}" FontSize="12"/>
                    <!-- Filter chips row — each chip is a Button bound to
                         ToggleSearchFilterCommand. Visual "active" state is
                         driven by the corresponding VM property via the chip's
                         ControlTemplate DataTrigger. -->
                    <Border DockPanel.Dock="Top" Padding="14,6" Margin="0,8,0,8">
                        <Border.Resources>
                            <!-- One Style for all six filter-chip buttons. The
                                 active appearance is set per-button via the
                                 chip's own DataTrigger (see each Button below). -->
                            <Style x:Key="FilterChipBase" TargetType="Button">
                                <Setter Property="Margin" Value="0,0,6,0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Command" Value="{Binding ToggleSearchFilterCommand}"/>
                            </Style>
                        </Border.Resources>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="FILTERS" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <!-- ALL QUALITIES — clears filter state -->
                            <Button Style="{StaticResource FilterChipBase}" CommandParameter="clear">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="9,3" BorderThickness="1"
                                                Background="#1500E5FF" BorderBrush="#8000E5FF">
                                            <TextBlock x:Name="tb" Text="ALL QUALITIES"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource AccentBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SearchFilterAnyActive}" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#660F2238"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource LineDimBrush}"/>
                                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Style="{StaticResource FilterChipBase}" CommandParameter="quality:1080p">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="9,3" BorderThickness="1"
                                                Background="#660F2238" BorderBrush="{DynamicResource LineDimBrush}">
                                            <TextBlock x:Name="tb" Text="1080p"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SearchFilterQuality}" Value="1080p">
                                                <Setter TargetName="bd" Property="Background" Value="#1500E5FF"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#8000E5FF"/>
                                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Style="{StaticResource FilterChipBase}" CommandParameter="quality:2160p">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="9,3" BorderThickness="1"
                                                Background="#660F2238" BorderBrush="{DynamicResource LineDimBrush}">
                                            <TextBlock x:Name="tb" Text="2160p"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SearchFilterQuality}" Value="2160p">
                                                <Setter TargetName="bd" Property="Background" Value="#1500E5FF"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#8000E5FF"/>
                                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Style="{StaticResource FilterChipBase}" CommandParameter="source:WEB">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="9,3" BorderThickness="1"
                                                Background="#660F2238" BorderBrush="{DynamicResource LineDimBrush}">
                                            <TextBlock x:Name="tb" Text="WEB"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SearchFilterSource}" Value="WEB">
                                                <Setter TargetName="bd" Property="Background" Value="#1500E5FF"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#8000E5FF"/>
                                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Style="{StaticResource FilterChipBase}" CommandParameter="source:BLURAY">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="9,3" BorderThickness="1"
                                                Background="#660F2238" BorderBrush="{DynamicResource LineDimBrush}">
                                            <TextBlock x:Name="tb" Text="BLURAY"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SearchFilterSource}" Value="BLURAY">
                                                <Setter TargetName="bd" Property="Background" Value="#1500E5FF"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#8000E5FF"/>
                                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Style="{StaticResource FilterChipBase}" CommandParameter="size:1GB">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd" Padding="9,3" BorderThickness="1"
                                                Background="#660F2238" BorderBrush="{DynamicResource LineDimBrush}">
                                            <TextBlock x:Name="tb" Text="&gt; 1GB"
                                                       FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                                                       Foreground="{DynamicResource TextDimBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding SearchFilterBigSize}" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1500E5FF"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#8000E5FF"/>
                                                <Setter TargetName="tb" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                    <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button Content="Download Selected" Command="{Binding DownloadSearchResultCommand}"
                                Padding="16,6" Style="{StaticResource PrimaryButton}"
                                ToolTip="Download all selected results (Ctrl+click to multi-select)"/>
                    </DockPanel>
                    <DataGrid ItemsSource="{Binding SearchResults}"
                              SelectedItem="{Binding SelectedSearchResult}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Extended" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              x:Name="SearchGrid"
                              SelectionChanged="SearchGrid_SelectionChanged"
                              PreviewMouseLeftButtonDown="DragSource_PreviewMouseLeftButtonDown"
                              MouseMove="DragSource_MouseMove">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Download Selected" Command="{Binding DownloadSearchResultCommand}" FontWeight="Bold"/>
                                <MenuItem Header="Copy Release Name" Command="{Binding CopySearchResultCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding DownloadSearchResultCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Release" Binding="{Binding ReleaseName}" Width="*"/>
                            <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" Width="90"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- Player Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="06" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Player" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Grid x:Name="PlayerTab" DataContext="{Binding Player}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="260" MaxWidth="420"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left sidebar -->
                    <DockPanel Grid.Column="0">
                        <!-- Search bar (always visible) -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                                Padding="6,5" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="&#x1F50D;"
                                        Command="{Binding SearchCommand}"
                                        Padding="7,4" Margin="4,0,0,0" Style="{StaticResource PrimaryButton}" FontSize="10"/>
                                <TextBox x:Name="PlayerSearchBox" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,4" FontSize="11.5" VerticalContentAlignment="Center"
                                         Background="{DynamicResource SurfaceLightBrush}"
                                         Foreground="{DynamicResource ForegroundBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"/>
                            </DockPanel>
                        </Border>

                        <!-- Mode tabs: Browse | Now Playing | Library -->
                        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Margin="4,3">
                                <RadioButton x:Name="BrowseMode" Content="Browse" IsChecked="True"
                                             Style="{StaticResource ModeTabStyle}"
                                             Padding="12,5" Margin="0,0,4,0" FontSize="11"/>
                                <RadioButton x:Name="NowPlayingMode" Content="Now Playing"
                                             Style="{StaticResource ModeTabStyle}"
                                             Padding="12,5" Margin="0,0,4,0" FontSize="11"/>
                                <RadioButton x:Name="LibraryMode" Content="Library"
                                             Style="{StaticResource ModeTabStyle}"
                                             Padding="12,5" FontSize="11"
                                             Checked="LibraryMode_Checked"/>
                            </StackPanel>
                        </Border>

                        <!-- Status bar -->
                        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}"
                                Padding="8,3" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                            <TextBlock Text="{Binding PlayerStatus}"
                                       Foreground="{DynamicResource ForegroundDimBrush}" FontSize="10"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <!-- ═══ BROWSE MODE ═══ -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsChecked, ElementName=BrowseMode, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Margin="8,6,8,6">

                                <!-- Search results (only when search has results) -->
                                <StackPanel Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibility}}">
                                    <DockPanel Margin="0,0,0,4">
                                        <Button DockPanel.Dock="Right" Content="Clear" FontSize="10"
                                                Command="{Binding ClearSearchCommand}"
                                                Style="{StaticResource SecondaryButton}" Padding="8,2"/>
                                        <TextBlock Text="Search Results" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding SearchResults}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,5,5" Cursor="Hand"
                                                        Background="{DynamicResource SurfaceBrush}"
                                                        CornerRadius="4" ClipToBounds="True"
                                                        MouseLeftButtonDown="SearchCard_Click">
                                                    <StackPanel>
                                                        <Border Height="135" ClipToBounds="True" CornerRadius="4,4,0,0">
                                                            <Image Source="{Binding PosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=95}"
                                                                   Stretch="UniformToFill" VerticalAlignment="Top"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>
                                                        <StackPanel Margin="3,2,3,3">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="9.5"
                                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                                       TextTrimming="CharacterEllipsis" MaxHeight="24"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                                <TextBlock Text="{Binding RatingDisplay}" FontSize="9"
                                                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Year}" FontSize="9" Margin="4,0,0,0"
                                                                           Foreground="{DynamicResource ForegroundDimBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Separator Margin="0,4,0,6" Background="{DynamicResource BorderBrush}"/>
                                </StackPanel>

                                <!-- Trending Movies -->
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="&#x21BB;" FontSize="10"
                                            Command="{Binding RefreshTrendingCommand}"
                                            Style="{StaticResource SecondaryButton}" Padding="6,2"
                                            ToolTip="Refresh trending"/>
                                    <TextBlock Text="&#x1F3AC; Trending Movies" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding TrendingMovies}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,5,5" Cursor="Hand"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    CornerRadius="4" ClipToBounds="True"
                                                    MouseLeftButtonDown="MovieCard_Click">
                                                <StackPanel>
                                                    <Border Height="135" ClipToBounds="True" CornerRadius="4,4,0,0">
                                                        <Image Source="{Binding PosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=95}"
                                                               Stretch="UniformToFill" VerticalAlignment="Top"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                    <StackPanel Margin="3,2,3,3">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="9.5"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="24"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                            <TextBlock Text="{Binding RatingDisplay}" FontSize="9"
                                                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Year}" FontSize="9" Margin="4,0,0,0"
                                                                       Foreground="{DynamicResource ForegroundDimBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Trending TV -->
                                <TextBlock Text="&#x1F4FA; Trending TV" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,6,0,4"/>
                                <ItemsControl ItemsSource="{Binding TrendingTvShows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Columns="3"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,5,5" Cursor="Hand"
                                                    Background="{DynamicResource SurfaceBrush}"
                                                    CornerRadius="4" ClipToBounds="True"
                                                    MouseLeftButtonDown="TvCard_Click">
                                                <StackPanel>
                                                    <Border Height="135" ClipToBounds="True" CornerRadius="4,4,0,0">
                                                        <Image Source="{Binding PosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=95}"
                                                               Stretch="UniformToFill" VerticalAlignment="Top"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                    <StackPanel Margin="3,2,3,3">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="9.5"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="24"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                                            <TextBlock Text="{Binding RatingDisplay}" FontSize="9"
                                                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Year}" FontSize="9" Margin="4,0,0,0"
                                                                       Foreground="{DynamicResource ForegroundDimBrush}"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══ NOW PLAYING MODE (detail + episodes + FTP results) ═══ -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsChecked, ElementName=NowPlayingMode, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Margin="8,6,8,6">
                                <!-- Selected media detail -->
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                        Padding="10" Margin="0,0,0,6"
                                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Left" Width="90" Margin="0,0,10,0"
                                                    CornerRadius="4" ClipToBounds="True"
                                                    Background="{DynamicResource SurfaceLightBrush}"
                                                    Visibility="{Binding HasDetailPoster, Converter={StaticResource BoolToVisibility}}">
                                                <Image Stretch="UniformToFill" VerticalAlignment="Top"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Source="{Binding DetailPosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=90}"/>
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DetailTitle}" FontWeight="Bold" FontSize="15"
                                                           Foreground="White" TextWrapping="Wrap" MaxHeight="40"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding DetailRating}" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                    <TextBlock Text="{Binding DetailYear}" FontSize="12" Margin="10,0,0,0"
                                                               Foreground="{DynamicResource ForegroundDimBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding DetailGenres}" FontSize="10.5" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource ForegroundDimBrush}"/>
                                                <TextBlock Text="{Binding DetailPlot}" TextWrapping="Wrap"
                                                           MaxHeight="48" FontSize="11" Margin="0,5,0,0"
                                                           LineHeight="15"
                                                           Foreground="{DynamicResource ForegroundDimBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Content="&#x1F50D; Search" Margin="0,8,0,0"
                                                        Command="{Binding SearchAndPlayCommand}"
                                                        Padding="14,6" Style="{StaticResource PrimaryButton}"
                                                        HorizontalAlignment="Left" FontSize="11"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- FTP Search Results -->
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                        Padding="10"
                                        Visibility="{Binding HasFtpResults, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="FTP Results" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                                        <DataGrid ItemsSource="{Binding FtpResults}"
                                                  SelectedItem="{Binding SelectedFtpResult}"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column" CanUserAddRows="False"
                                                  MaxHeight="160"
                                                  MouseDoubleClick="PlayerResult_DoubleClick">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Release" Binding="{Binding ReleaseName}" Width="*"/>
                                                <DataGridTextColumn Header="Server" Binding="{Binding ServerName}" Width="60"/>
                                                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="55"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Button Content="&#x25B6; Play Selected" Command="{Binding PlayResultCommand}"
                                                Padding="14,5" Margin="0,6,0,0" HorizontalAlignment="Left"
                                                Style="{StaticResource PrimaryButton}" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- Torrent Results -->
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                        Padding="10" Margin="0,6,0,0"
                                        Visibility="{Binding HasTorrentResults, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <TextBlock Text="Torrent Results" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,6"/>
                                        <DataGrid ItemsSource="{Binding TorrentResults}"
                                                  SelectedItem="{Binding SelectedTorrentResult}"
                                                  AutoGenerateColumns="False" IsReadOnly="True"
                                                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                                                  HeadersVisibility="Column" CanUserAddRows="False"
                                                  MaxHeight="160"
                                                  MouseDoubleClick="TorrentResult_DoubleClick">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Name" Binding="{Binding Title}" Width="*"/>
                                                <DataGridTextColumn Header="S" Binding="{Binding SeedsDisplay}" Width="35">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="L" Binding="{Binding LeechesDisplay}" Width="35">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="65"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Button Content="&#x25B6; Play Torrent" Command="{Binding PlayTorrentCommand}"
                                                Padding="14,5" Margin="0,6,0,0" HorizontalAlignment="Left"
                                                Style="{StaticResource PrimaryButton}" FontSize="11"/>
                                    </StackPanel>
                                </Border>

                                <!-- Empty state hint -->
                                <Border Visibility="{Binding HasNoSelection, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,30,0,0">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="No selection" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                        <TextBlock Text="Click a movie or TV show in Browse to see details."
                                                   FontSize="11" Foreground="{DynamicResource ForegroundDimBrush}"
                                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="250"/>
                                    </StackPanel>
                                </Border>

                                <!-- TV Episode Picker -->
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                                        Padding="10" Margin="0,0,0,6"
                                        Visibility="{Binding ShowEpisodePicker, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="Episodes" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"/>
                                            <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding Seasons}"
                                                      SelectedItem="{Binding SelectedSeason}"
                                                      DisplayMemberPath="Name" Width="150" FontSize="11"
                                                      HorizontalAlignment="Right"/>
                                        </DockPanel>
                                        <ItemsControl ItemsSource="{Binding Episodes}" MaxHeight="200">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceLightBrush}" CornerRadius="3"
                                                            Padding="8,5" Margin="0,0,0,2" Cursor="Hand"
                                                            MouseLeftButtonDown="Episode_Click">
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Runtime, StringFormat={}{0}m}"
                                                                       FontSize="10" Foreground="{DynamicResource ForegroundDimBrush}"
                                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource ForegroundBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- ═══ LIBRARY MODE ═══ -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsChecked, ElementName=LibraryMode, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Margin="8,6,8,6">
                                <TextBlock Text="&#x1F4BF; Downloaded Library" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding LibraryItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="4"
                                                    Padding="10,7" Margin="0,0,0,4" Cursor="Hand"
                                                    MouseLeftButtonDown="LibraryItem_Click">
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding SizeText}" FontSize="10"
                                                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                                                   HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding ResumePercent}" FontSize="10"
                                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ReleaseName}" FontWeight="SemiBold" FontSize="11"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding FileName}" FontSize="10" Margin="0,2,0,0"
                                                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="Transparent"/>

                    <!-- Right: Video Player + Controls -->
                    <DockPanel Grid.Column="2">
                        <!-- Transport controls -->
                        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                Padding="8,5">
                            <StackPanel>
                                <Slider Value="{Binding Position, Mode=OneWay}" Minimum="0" Maximum="100" IsMoveToPointEnabled="True"
                                        Margin="0,0,0,3"
                                        x:Name="PlayerSeekBar"
                                        Thumb.DragCompleted="SeekBar_DragCompleted" PreviewMouseLeftButtonUp="SeekBar_MouseUp"/>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="&#x25B6;&#xFE0E;" Command="{Binding PlayPauseCommand}"
                                                Padding="6,3" Margin="0,0,4,0" Style="{StaticResource PrimaryButton}"
                                                FontSize="13" Width="32" ToolTip="Play / Pause (Space)"/>
                                        <Button Content="&#x25A0;" Command="{Binding StopCommand}"
                                                Padding="6,3" Margin="0,0,8,0" Style="{StaticResource SecondaryButton}"
                                                FontSize="11" Width="32" ToolTip="Stop"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11" FontFamily="Consolas"
                                                   Foreground="{DynamicResource ForegroundDimBrush}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ComboBox ItemsSource="{Binding AudioTracks}"
                                                  SelectedIndex="{Binding AudioTrackIndex}"
                                                  Width="75" FontSize="9" Margin="0,0,4,0"
                                                  ToolTip="Audio track"/>
                                        <ComboBox ItemsSource="{Binding SubtitleTracks}"
                                                  SelectedIndex="{Binding SubtitleTrackIndex}"
                                                  Width="75" FontSize="9" Margin="0,0,6,0"
                                                  ToolTip="Subtitle track"/>
                                        <!-- Cast button -->
                                        <Button x:Name="CastButton" Content="&#x1F4E1;&#xFE0E;" FontSize="12"
                                                Padding="4,2" Margin="0,0,6,0" VerticalAlignment="Center"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="CastButton_Click">
                                            <Button.ToolTip>
                                                <MultiBinding StringFormat="{}{0}">
                                                    <Binding Path="CastButtonTooltip"/>
                                                </MultiBinding>
                                            </Button.ToolTip>
                                            <Button.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <ContextMenu.Resources>
                                                        <Style x:Key="RendererItem" TargetType="MenuItem">
                                                            <Setter Property="Header" Value="{Binding Name}"/>
                                                            <Setter Property="Command"
                                                                    Value="{Binding DataContext.CastToDeviceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Setter Property="CommandParameter" Value="{Binding}"/>
                                                        </Style>
                                                    </ContextMenu.Resources>
                                                    <MenuItem Header="Cast to" ItemsSource="{Binding Renderers}"
                                                              ItemContainerStyle="{StaticResource RendererItem}"
                                                              Visibility="{Binding HasRenderers, Converter={StaticResource BoolToVisibility}}"/>
                                                    <MenuItem Header="No devices found" IsEnabled="False"
                                                              Visibility="{Binding HasNoRenderers, Converter={StaticResource BoolToVisibility}}"/>
                                                    <Separator Visibility="{Binding IsCasting, Converter={StaticResource BoolToVisibility}}"/>
                                                    <MenuItem Header="Stop casting" Command="{Binding StopCastingCommand}"
                                                              Visibility="{Binding IsCasting, Converter={StaticResource BoolToVisibility}}"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                        </Button>
                                        <TextBlock Text="&#x1F50A;" VerticalAlignment="Center" Margin="0,0,3,0" FontSize="10"/>
                                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" Width="70" MinWidth="50"
                                                VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Border/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Video area -->
                        <Grid Background="Black" x:Name="PlayerVideoArea" MouseLeftButtonDown="VideoArea_MouseDown">
                            <!-- NO SIGNAL overlay (rendered behind VideoView; visible when video is idle) -->
                            <Grid IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.85">
                                    <TextBlock Text="NO SIGNAL" FontFamily="{DynamicResource DisplayFontFamily}" FontWeight="Bold"
                                               FontSize="48" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#00E5FF" BlurRadius="18" ShadowDepth="0" Opacity="0.8"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="WAITING FOR A SOURCE..." Style="{DynamicResource MicroTextStyle}"
                                               FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                            <vlc:VideoView x:Name="PlayerVideoView"/>
                            <!-- Buffering overlay -->
                            <Border Background="#CC000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Visibility="{Binding IsBuffering, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#x23F3; Buffering..." FontSize="18" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <ProgressBar Value="{Binding BufferProgress}" Maximum="100"
                                                 Width="200" Height="6" Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="{Binding PlayerStatus}" FontSize="12"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- Upcoming Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="07" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Upcoming" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                            <TextBlock Text="&gt;&gt; UPCOMING RELEASES" Style="{DynamicResource SectionHeaderTextStyle}"/>
                        </Border>
                        <Grid>
                            <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                            <DockPanel Margin="12">
                    <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6" Padding="8,6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Refresh" Command="{Binding LoadUpcomingCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Add to Wishlist" Command="{Binding AddUpcomingToWishlistCommand}"
                                    Padding="12,6" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}"/>
                            <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding QualityOptions}"
                                      SelectedItem="{Binding UpcomingQualityText}" Width="90"/>
                            <TextBlock Text="{Binding UpcomingStatus}" VerticalAlignment="Center"
                                       Margin="16,0,0,0" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border DockPanel.Dock="Bottom" Height="155"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Margin="0,10,0,0" Padding="14"
                            Visibility="{Binding HasUpcomingSelection, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <Border DockPanel.Dock="Left" Width="95" Margin="0,0,16,0"
                                    CornerRadius="4" ClipToBounds="True"
                                    Background="{DynamicResource SurfaceLightBrush}"
                                    Visibility="{Binding HasUpcomingPoster, Converter={StaticResource BoolToVisibility}}">
                                <Image Stretch="UniformToFill" VerticalAlignment="Top"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="{Binding UpcomingPosterUrl, Converter={StaticResource ImageUrlConverter}, ConverterParameter=120}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="{Binding UpcomingDetailTitle}" FontWeight="Bold" FontSize="16"
                                           Foreground="White"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding UpcomingRating}" FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                    <TextBlock Text="{Binding UpcomingGenres}" FontSize="12.5"
                                               Foreground="{DynamicResource ForegroundDimBrush}"
                                               Margin="14,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding UpcomingPlot}" TextWrapping="Wrap"
                                           MaxHeight="65" FontSize="12.5" Margin="0,8,0,0"
                                           LineHeight="18"
                                           Foreground="{DynamicResource ForegroundDimBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <DockPanel Grid.Column="0">
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                <TextBlock Text="{Binding TvScheduleHeader}" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ComboBox ItemsSource="{Binding TvTypeOptions}"
                                              SelectedItem="{Binding TvTypeFilter}"
                                              Width="90" FontSize="11" Margin="0,0,6,0"
                                              ToolTip="Filter by show type"/>
                                    <TextBox Text="{Binding ShowSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                             Width="140" VerticalContentAlignment="Center" FontSize="11.5"
                                             Margin="0,0,4,0">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding SearchShowScheduleCommand}"/>
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Content="Search" Command="{Binding SearchShowScheduleCommand}"
                                            Padding="8,3" FontSize="11" Style="{StaticResource PrimaryButton}"/>
                                    <Button Content="X" Command="{Binding ClearShowSearchCommand}"
                                            Padding="6,3" Margin="4,0,0,0" FontSize="11"
                                            Style="{StaticResource SecondaryButton}"
                                            Visibility="{Binding IsShowSearchActive, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </DockPanel>
                            <DataGrid ItemsSource="{Binding UpcomingTvEpisodes}"
                                      SelectedItem="{Binding SelectedTvEpisode}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="75"/>
                                    <DataGridTextColumn Header="Show" Binding="{Binding ShowName}" Width="*"/>
                                    <DataGridTextColumn Header="Network" Binding="{Binding NetworkDisplay}" Width="80"/>
                                    <DataGridTextColumn Header="Episode" Binding="{Binding EpisodeInfo}" Width="140"/>
                                    <DataGridTextColumn Header="Time" Binding="{Binding TimeDisplay}" Width="55"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                      Background="Transparent"/>
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Margin="0,0,0,6">
                                <Run Text="Movie Releases"/>
                            </TextBlock>
                            <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" FontSize="11"
                                       Foreground="{DynamicResource ForegroundDimBrush}"
                                       Visibility="{Binding HasNoTmdbKey, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="Configure TMDb API key in Settings &#x2192; Downloads to see movie releases."/>
                            </TextBlock>
                            <DataGrid ItemsSource="{Binding UpcomingMovies}"
                                      SelectedItem="{Binding SelectedUpcomingMovie}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*"/>
                                    <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="50"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding ReleaseDateDisplay}" Width="85"/>
                                    <DataGridTextColumn Header="Genres" Binding="{Binding Genres}" Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- ===== COMMS group ===== -->
            <TabItem IsEnabled="False" Focusable="False" IsHitTestVisible="False" Padding="14,12,14,4">
                <TabItem.Header>
                    <TextBlock Text="&#x25B8; COMMS" FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="9" Foreground="{DynamicResource TextFaintBrush}" Margin="0,8,0,0"/>
                </TabItem.Header>
            </TabItem>

            <!-- IRC Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="08" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="IRC" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <DockPanel Margin="12">
                    <!-- Outer IRC HUD panel -->
                    <Border Style="{DynamicResource HudPanelStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; IRC" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <DockPanel Margin="6">
                                    <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                            Padding="8,4" Margin="0,0,0,6">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Reconnect" Command="{Binding Irc.ReconnectCommand}"
                                                    Padding="10,2" Margin="4,0,0,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
                                            <Button DockPanel.Dock="Right" Content="Disconnect" Command="{Binding Irc.DisconnectCommand}"
                                                    Padding="10,2" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" FontSize="11"/>
                                            <TextBlock Text="{Binding Irc.TopicText}" TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource ForegroundDimBrush}" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>
                                    <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                                        <Border Background="{DynamicResource SurfaceBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                                Padding="8,6">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right" Content="Send" Command="{Binding Irc.SendCommand}"
                                                        Padding="16,6" Margin="6,0,0,0" Style="{StaticResource PrimaryButton}"/>
                                                <TextBox Text="{Binding Irc.InputText, UpdateSourceTrigger=PropertyChanged}"
                                                         VerticalContentAlignment="Center" x:Name="IrcInputBox">
                                                    <TextBox.InputBindings>
                                                        <KeyBinding Key="Return" Command="{Binding Irc.SendCommand}"/>
                                                    </TextBox.InputBindings>
                                                </TextBox>
                                            </DockPanel>
                                        </Border>
                                    </DockPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Channels inner panel -->
                                        <Border Grid.Column="0" Margin="0,0,6,0" Style="{DynamicResource HudPanelStyle}">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                                    <TextBlock Text="&gt;&gt; CHANNELS" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                                </Border>
                                                <Grid>
                                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                                    <ListBox ItemsSource="{Binding Irc.Channels}"
                                                             SelectedItem="{Binding Irc.SelectedChannel}"
                                                             Background="Transparent" BorderThickness="0">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="&#x1F512;" FontSize="10" Margin="0,0,4,0"
                                                                               Visibility="{Binding HasFishKey, Converter={StaticResource BoolToVisibility}}"/>
                                                                    <TextBlock Text="{Binding SidebarDisplay}" Foreground="{DynamicResource ForegroundBrush}"/>
                                                                    <TextBlock Text="{Binding UnreadDisplay}" Foreground="{DynamicResource AccentBrush}"
                                                                               FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </DockPanel>
                                        </Border>
                                        <!-- Messages inner panel -->
                                        <Border Grid.Column="1" Margin="0,0,6,0" Style="{DynamicResource HudPanelStyle}">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                                    <TextBlock Text="&gt;&gt; MESSAGES" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                                </Border>
                                                <Grid>
                                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                                    <ListBox ItemsSource="{Binding Irc.Messages}"
                                                             x:Name="IrcMessageList"
                                                             Background="Transparent" BorderThickness="0"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                             VirtualizingPanel.ScrollUnit="Pixel">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="4,1">
                                                                    <TextBlock Text="{Binding Timestamp}" Foreground="{DynamicResource ForegroundDimBrush}"
                                                                               FontSize="11" Margin="0,0,6,0" FontFamily="Consolas"/>
                                                                    <TextBlock Text="&#x1F512;" FontSize="9" Margin="0,0,3,0"
                                                                               Visibility="{Binding WasEncrypted, Converter={StaticResource BoolToVisibility}}"/>
                                                                    <TextBlock ui:ReleaseTextHelper.Message="{Binding}"
                                                                               ui:ReleaseTextHelper.ClickCommand="{Binding DataContext.Irc.ReleaseLinkClickedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{Binding NickColor}" FontFamily="Consolas" FontSize="12.5">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSystemMessage}" Value="True">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource ForegroundDimBrush}"/>
                                                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </DockPanel>
                                        </Border>
                                        <!-- Users inner panel -->
                                        <Border Grid.Column="2" Style="{DynamicResource HudPanelStyle}">
                                            <DockPanel>
                                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                                    <TextBlock Text="&gt;&gt; USERS" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                                </Border>
                                                <Grid>
                                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                                    <ListBox ItemsSource="{Binding Irc.NickList}" x:Name="IrcNickList"
                                                             Background="Transparent" BorderThickness="0" FontSize="12">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <!-- Per-item context menu: {Binding} resolves to the
                                                                     actual right-clicked nick (a string), not the
                                                                     ListBox.SelectedItem which may be stale or null
                                                                     because WPF doesn't auto-select on right-click.
                                                                     Find ancestor Window via DataContext to reach
                                                                     the DashboardViewModel.Irc.* commands. -->
                                                                <TextBlock Text="{Binding}" Foreground="{DynamicResource ForegroundBrush}">
                                                                    <TextBlock.ContextMenu>
                                                                        <ContextMenu>
                                                                            <MenuItem Header="Private Message"
                                                                                      Command="{Binding PlacementTarget.Tag.DataContext.Irc.PrivateMessageNickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                      CommandParameter="{Binding}"/>
                                                                            <MenuItem Header="FiSH Key Exchange"
                                                                                      Command="{Binding PlacementTarget.Tag.DataContext.Irc.KeyExchangeNickCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                                      CommandParameter="{Binding}"/>
                                                                        </ContextMenu>
                                                                    </TextBlock.ContextMenu>
                                                                    <!-- Tag chains the per-item TextBlock to the
                                                                         hosting Window so the ContextMenu can reach
                                                                         the DataContext via PlacementTarget.Tag. -->
                                                                    <TextBlock.Tag>
                                                                        <Binding RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </TextBlock.Tag>
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </DockPanel>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- PreDB Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="09" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="PreDB" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                            <TextBlock Text="&gt;&gt; PREDB" Style="{DynamicResource SectionHeaderTextStyle}"/>
                        </Border>
                        <Grid>
                            <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                            <DockPanel Margin="12">
                    <!-- Search bar -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding CancelPreDbSearchCommand}"
                                Padding="12,6" Margin="6,0,0,0" Style="{StaticResource SecondaryButton}"
                                Visibility="{Binding IsPreDbSearching, Converter={StaticResource BoolToVisibility}}"/>
                        <Button DockPanel.Dock="Right" Content="Search" Command="{Binding SearchPreDbCommand}"
                                Padding="18,6" Margin="6,0,0,0" Style="{StaticResource PrimaryButton}"/>
                        <ComboBox DockPanel.Dock="Right" Width="90" Margin="6,0,0,0"
                                  ItemsSource="{Binding PreDbSectionFilters}"
                                  SelectedItem="{Binding PreDbSectionFilter}"
                                  Background="{DynamicResource SurfaceBrush}"
                                  Foreground="{DynamicResource ForegroundBrush}" FontSize="12"/>
                        <TextBox Text="{Binding PreDbQuery, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SearchPreDbCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>
                    <!-- Status + progress -->
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="{Binding PreDbStatus}" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="12"/>
                        <ProgressBar Value="{Binding PreDbRefreshProgress}" Minimum="0" Maximum="100"
                                     Height="3" Margin="12,0,0,0" VerticalAlignment="Center"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="{DynamicResource SurfaceBrush}"/>
                    </DockPanel>
                    <!-- Results grid -->
                    <DataGrid ItemsSource="{Binding PreDbItems}" SelectedItem="{Binding SelectedPreDbItem}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" CanUserAddRows="False">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Search on Servers" Command="{Binding SearchPreDbOnServersCommand}" FontWeight="Bold"/>
                                <MenuItem Header="Race / Spread" Command="{Binding RacePreDbCommand}"/>
                                <Separator/>
                                <MenuItem Header="Copy Release Name" Command="{Binding CopyPreDbReleaseCommand}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNuked}" Value="True">
                                        <Setter Property="Foreground" Value="#F44336"/>
                                        <Setter Property="ToolTip" Value="{Binding NukeReason, StringFormat='NUKED: {0}'}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Release" Binding="{Binding Name}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNuked}" Value="True">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Group" Binding="{Binding Team}" Width="90"/>
                            <DataGridTextColumn Header="Section" Binding="{Binding Category}" Width="110"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="70"/>
                            <DataGridTextColumn Header="Files" Binding="{Binding Files}" Width="45"/>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- ===== TRANSFERS group ===== -->
            <TabItem IsEnabled="False" Focusable="False" IsHitTestVisible="False" Padding="14,12,14,4">
                <TabItem.Header>
                    <TextBlock Text="&#x25B8; TRANSFERS" FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="9" Foreground="{DynamicResource TextFaintBrush}" Margin="0,8,0,0"/>
                </TabItem.Header>
            </TabItem>

            <!-- Spread Tab -->
            <TabItem x:Name="SpreadTab">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="10" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Spread" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Grid Margin="12">
                    <!-- Setup Guide (shown when no sections configured) -->
                    <Border Visibility="{Binding NeedSetup, Converter={StaticResource BoolToVisibility}}"
                            Background="{DynamicResource SurfaceBrush}" CornerRadius="8"
                            Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center"
                            MaxWidth="600">
                        <StackPanel>
                            <TextBlock Text="Spread / FXP Setup" FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,16"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="0,0,0,12"
                                       Text="The Spread engine lets you race and FXP releases between your connected servers. To get started:"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,4"
                                       Text="1. Go to Settings > Servers tab and click Edit on each server you want to use."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,4"
                                       Text="2. Scroll to the 'Spread / FXP' section at the bottom of the server edit dialog."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,4"
                                       Text="3. Add sections as Name=Path (e.g. MP3=/site/mp3, 0DAY=/site/0day), one per line."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,4"
                                       Text="4. Set the priority (Normal/High/VeryHigh), max upload/download slots, and optionally skiplist rules."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,4"
                                       Text="5. Repeat for each server. At least 2 servers must share the same section name to race."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,4"
                                       Text="6. (Optional) In Settings > Spread tab, adjust pool size, timeouts, and global skiplist rules."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource ForegroundDimBrush}" FontSize="13" Margin="12,0,0,16"
                                       Text="7. Come back here, pick a section, type a release name, and click New Race."/>
                            <Button Content="Open Settings" Command="{Binding OpenSettingsCommand}"
                                    Padding="16,8" HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </Border>
                    <!-- Main spread UI (shown when sections exist) -->
                    <Border Visibility="{Binding HasSections, Converter={StaticResource BoolToVisibility}}"
                            Style="{DynamicResource HudPanelStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; SPREAD ENGINE" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <DockPanel Focusable="True">
                    <DockPanel.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding StopJobCommand}"/>
                        <KeyBinding Gesture="Ctrl+R" Command="{Binding StartRaceCommand}"/>
                    </DockPanel.InputBindings>
                    <!-- Stats cards row -->
                    <Border DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="ACTIVE RACES" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding ActiveJobs.Count, FallbackValue=0}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="LEADER" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding LeaderScore, FallbackValue=—}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="QUEUE" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding QueueDepth, FallbackValue=0}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{DynamicResource StatCardStyle}">
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <StackPanel Margin="4">
                                        <TextBlock Text="HISTORY" Style="{DynamicResource StatCardLabelStyle}"/>
                                        <TextBlock Text="{Binding History.Count, FallbackValue=0}" Style="{DynamicResource StatCardValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="6" Padding="8,6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="New Race" Command="{Binding StartRaceCommand}"
                                    Padding="12,6" Margin="0,0,6,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="Stop" Command="{Binding StopJobCommand}"
                                    Padding="12,6" Margin="0,0,12,0" Style="{StaticResource SecondaryButton}"/>
                            <ComboBox ItemsSource="{Binding SpreadSections}"
                                      SelectedItem="{Binding SelectedSection}"
                                      Width="120" Margin="0,0,6,0" ToolTip="Section"/>
                            <TextBox Text="{Binding SpreadReleaseName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="280" VerticalContentAlignment="Center"
                                     ToolTip="Release name" Margin="0,0,6,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding StartRaceCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Content="Settings" Command="{Binding OpenSettingsCommand}"
                                    Padding="12,6" Style="{StaticResource SecondaryButton}"/>
                        </StackPanel>
                    </Border>
                    <!-- Status -->
                    <TextBlock DockPanel.Dock="Top" Text="{Binding SpreadStatus}" FontSize="12"
                               Foreground="{DynamicResource ForegroundDimBrush}" Margin="0,0,0,8"
                               TextWrapping="Wrap"/>
                    <!-- Main 2-row layout: AUTO RACES (top, 2*) + SITE SCOREBOARD + AUTO-RACE FEED (bottom, 1*) -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        <!-- AUTO RACES panel -->
                        <Border Grid.Row="0" Style="{DynamicResource HudPanelStyle}" Margin="0,0,0,10">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                    <TextBlock Text="&gt;&gt; AUTO RACES" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                </Border>
                                <Grid>
                                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="14">
                                        <ItemsControl ItemsSource="{Binding SpreadJobs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10" Background="#80050F1A"
                                                            BorderBrush="{DynamicResource LineBrush}" BorderThickness="1"
                                                            Padding="14,12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="260"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Big score on the left -->
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Score, FallbackValue=0, StringFormat=N0}"
                                                                           FontFamily="{DynamicResource DisplayFontFamily}"
                                                                           FontWeight="Bold" FontSize="42"
                                                                           Foreground="{DynamicResource AccentBrush}">
                                                                    <TextBlock.Effect>
                                                                        <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.45"/>
                                                                    </TextBlock.Effect>
                                                                </TextBlock>
                                                                <TextBlock Text="{Binding ScoreLabel, FallbackValue=AUTO RACE}"
                                                                           Style="{DynamicResource MicroTextStyle}"
                                                                           Margin="0,-4,0,0"/>
                                                            </StackPanel>
                                                            <!-- Center: release + section/files + source/dest + chips -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,14,0">
                                                                <TextBlock Text="{Binding Release}" Style="{DynamicResource DisplayTextStyle}" FontSize="14"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <TextBlock Text="{Binding Section}" Style="{DynamicResource MicroTextStyle}"/>
                                                                    <TextBlock Text=" · " Foreground="{DynamicResource TextFaintBrush}"/>
                                                                    <TextBlock Text="{Binding FilesDoneTotalDisplay, FallbackValue=0 / 0}" Style="{DynamicResource MicroTextStyle}"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                    <TextBlock Text="{Binding SourceDisplay, FallbackValue=—}" Style="{DynamicResource AccentTextStyle}" FontSize="11"/>
                                                                    <TextBlock Text=" → " Foreground="{DynamicResource TextDimBrush}" Margin="6,0"/>
                                                                    <TextBlock Text="{Binding DestDisplay, FallbackValue=—}" Style="{DynamicResource AccentTextStyle}" FontSize="11" Foreground="{DynamicResource Signature2Brush}"/>
                                                                </StackPanel>
                                                                <!-- Tag chips row -->
                                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                                    <Border Style="{DynamicResource TagAccentStyle}" Margin="0,0,6,0"
                                                                            Visibility="{Binding IsAutoRace, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                                                                        <TextBlock Text="AUTO" Style="{DynamicResource TagTextStyle}" Foreground="{DynamicResource AccentBrush}"/>
                                                                    </Border>
                                                                    <Border Style="{DynamicResource TagAccentStyle}" Margin="0,0,6,0"
                                                                            Visibility="{Binding IsPred, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                                                                        <TextBlock Text="PRED" Style="{DynamicResource TagTextStyle}" Foreground="{DynamicResource AccentBrush}"/>
                                                                    </Border>
                                                                    <Border Style="{DynamicResource TagWarnStyle}" Margin="0,0,6,0"
                                                                            Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                                                                        <TextBlock Text="PAUSED" Style="{DynamicResource TagTextStyle}" Foreground="{DynamicResource WarnBrush}"/>
                                                                    </Border>
                                                                    <Border Style="{DynamicResource TagGoodStyle}">
                                                                        <TextBlock Text="{Binding Status, FallbackValue=ACTIVE}" Style="{DynamicResource TagTextStyle}" Foreground="{DynamicResource GoodBrush}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <!-- Sparkline -->
                                                            <Border Grid.Column="2" Height="60" VerticalAlignment="Center"
                                                                    Background="#80070F1C" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" ClipToBounds="True">
                                                                <Polyline Points="{Binding SparklinePoints}"
                                                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.4"
                                                                          Stretch="Fill">
                                                                    <Polyline.Effect>
                                                                        <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                                                                    </Polyline.Effect>
                                                                </Polyline>
                                                            </Border>
                                                            <!-- Actions -->
                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                                                                <!-- PAUSE: visible only while the job is running (IsPaused=false) -->
                                                                <Button Content="PAUSE" Margin="0,0,6,0" Padding="10,5"
                                                                        Command="{Binding DataContext.PauseJobCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <!-- RESUME: visible only while paused -->
                                                                <Button Content="RESUME" Margin="0,0,6,0" Padding="10,5"
                                                                        Command="{Binding DataContext.ResumeJobCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="STOP"
                                                                        Command="{Binding DataContext.StopJobCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{DynamicResource DangerButtonStyle}" Padding="12,5"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </DockPanel>
                        </Border>
                        <!-- Bottom split: Scoreboard + AutoRaceFeed -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- SITE SCOREBOARD -->
                            <Border Grid.Column="0" Style="{DynamicResource HudPanelStyle}" Margin="0,0,5,0">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                        <TextBlock Text="&gt;&gt; SITE SCOREBOARD" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                    </Border>
                                    <Grid>
                                        <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                        <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                        <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                        <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="14">
                                            <ItemsControl ItemsSource="{Binding SpreadScoreboard}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="160"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding SiteName}" Style="{DynamicResource DisplayTextStyle}" FontSize="13"/>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <TextBlock Style="{DynamicResource MicroTextStyle}">
                                                                    <Run Text="{Binding FilesOwned}"/><Run Text=" / "/><Run Text="{Binding FilesTotal}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2" Text="{Binding SpeedFormatted, FallbackValue=—}"
                                                                       Style="{DynamicResource MicroTextStyle}" Margin="0,0,8,0"/>
                                                            <Border Grid.Column="3" Style="{DynamicResource TagAccentStyle}">
                                                                <TextBlock Text="{Binding Status, FallbackValue=READY}" Style="{DynamicResource TagTextStyle}"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </DockPanel>
                            </Border>
                            <!-- AUTO-RACE FEED -->
                            <Border Grid.Column="1" Style="{DynamicResource HudPanelStyle}" Margin="5,0,0,0">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                        <TextBlock Text="&gt;&gt; AUTO-RACE FEED" Style="{DynamicResource SectionHeaderTextStyle}"/>
                                    </Border>
                                    <Grid>
                                        <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                        <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                        <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                        <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="14">
                                            <ItemsControl ItemsSource="{Binding AutoRaceFeed}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                            <TextBlock Text="{Binding Timestamp}" Style="{DynamicResource MicroTextStyle}" Width="70"/>
                                                            <TextBlock Text="{Binding Action}" Style="{DynamicResource AccentTextStyle}" FontSize="11" Width="80"/>
                                                            <TextBlock Text="{Binding Release}" Style="{DynamicResource MicroTextStyle}" Foreground="{DynamicResource ForegroundBrush}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                                </DockPanel>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Browse Tab -->
            <TabItem x:Name="BrowseTab">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="11" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Browse" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                            <TextBlock Text="&gt;&gt; BROWSE" Style="{DynamicResource SectionHeaderTextStyle}"/>
                        </Border>
                        <Grid>
                            <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                            <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                            <DockPanel Margin="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Left Pane -->
                        <DockPanel Grid.Column="0" Margin="0,0,6,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox ItemsSource="{Binding ServerList}"
                                          SelectedItem="{Binding LeftServer}"
                                          Width="140" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding LeftPath, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" VerticalContentAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="Go" Command="{Binding LeftGoCommand}"
                                        Padding="12,4" Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding LeftItems}"
                                      SelectedItem="{Binding SelectedLeftItem}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Extended" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      EnableRowVirtualization="True">
                                <DataGrid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding LeftDoubleClickCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </DataGrid.InputBindings>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="80"/>
                                    <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedFormatted}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        <!-- Center Buttons -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="6">
                            <Button Content="FXP &#x2192;" Command="{Binding FxpRightCommand}"
                                    Padding="12,8" Margin="0,0,0,6" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="&#x2190; FXP" Command="{Binding FxpLeftCommand}"
                                    Padding="12,8" Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                        <!-- Right Pane -->
                        <DockPanel Grid.Column="2" Margin="6,0,0,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                                <ComboBox ItemsSource="{Binding ServerList}"
                                          SelectedItem="{Binding RightServer}"
                                          Width="140" Margin="0,0,6,0"/>
                                <TextBox Text="{Binding RightPath, UpdateSourceTrigger=PropertyChanged}"
                                         Width="200" VerticalContentAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="Go" Command="{Binding RightGoCommand}"
                                        Padding="12,4" Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding RightItems}"
                                      SelectedItem="{Binding SelectedRightItem}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Extended" GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      EnableRowVirtualization="True">
                                <DataGrid.InputBindings>
                                    <MouseBinding Gesture="LeftDoubleClick"
                                                  Command="{Binding RightDoubleClickCommand}"
                                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </DataGrid.InputBindings>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="80"/>
                                    <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedFormatted}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                            </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </TabItem>

            <!-- ===== SYSTEM group ===== -->
            <TabItem IsEnabled="False" Focusable="False" IsHitTestVisible="False" Padding="14,12,14,4">
                <TabItem.Header>
                    <TextBlock Text="&#x25B8; SYSTEM" FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="9" Foreground="{DynamicResource TextFaintBrush}" Margin="0,8,0,0"/>
                </TabItem.Header>
            </TabItem>

            <!-- Mounts Tab -->
            <TabItem x:Name="MountsTab">
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="12" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Mounts" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <DockPanel Margin="12">
                    <!-- Top: Mount cards row -->
                    <Border DockPanel.Dock="Top" Margin="0,0,0,12" Style="{DynamicResource HudPanelStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; MOUNT POINTS" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding MountedServerStatus}" Margin="14">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="280" Height="280" Margin="0,0,12,0"
                                                        Background="#80050F1A" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                                        <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                                        <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                                        <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                                        <DockPanel Margin="16">
                                                            <!-- Title -->
                                                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                                                <TextBlock Text="{Binding Name}" Style="{DynamicResource DisplayTextStyle}" FontSize="15"/>
                                                                <TextBlock Text="{Binding Host}" Style="{DynamicResource MicroTextStyle}" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <!-- Action buttons -->
                                                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                                                <Button Content="OPEN" Style="{DynamicResource CyberpunkButtonStyle}" Margin="0,0,6,0" Padding="14,5"
                                                                        Command="{Binding DataContext.OpenMountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding ServerId}"/>
                                                                <Button Content="FLUSH" Style="{DynamicResource CyberpunkButtonStyle}" Margin="0,0,6,0" Padding="14,5"
                                                                        Command="{Binding DataContext.FlushMountCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding ServerId}"/>
                                                                <!-- MOUNT: visible when not connected (IsMounted=false on
                                                                     OverviewServerVm — that's "any alive state including just-
                                                                     connected"; for the literal "drive letter mounted" we'd need
                                                                     a separate flag, but the button label "MOUNT" / "UNMOUNT"
                                                                     reads correctly given the user's mental model: MOUNT to bring
                                                                     online, UNMOUNT to take offline). -->
                                                                <Button Content="MOUNT" Padding="14,5"
                                                                        Command="{Binding DataContext.MountServerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding ServerId}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMounted}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                                <Button Content="UNMOUNT" Padding="14,5"
                                                                        Command="{Binding DataContext.UnmountServerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding ServerId}">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsMounted}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                </Button>
                                                            </StackPanel>
                                                            <!-- Status tag (color-coded by SiteTag: green=alive, cyan=MOUNTED, red=offline) -->
                                                            <Border DockPanel.Dock="Bottom" Style="{DynamicResource ServerStatusTagStyle}" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                                <TextBlock Text="{Binding StatusLine}" Style="{DynamicResource ServerStatusTextStyle}"/>
                                                            </Border>
                                                            <!-- Big disc (Stroke + glow recoloring driven by SiteTag) -->
                                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <Ellipse Width="130" Height="130" Stroke="{DynamicResource LineDimBrush}" StrokeThickness="2"/>
                                                                <Ellipse Width="130" Height="130" StrokeThickness="3"
                                                                        Style="{DynamicResource ServerStatusRingStyle}"
                                                                        StrokeDashArray="2,1.2" RenderTransformOrigin="0.5,0.5">
                                                                    <Ellipse.RenderTransform>
                                                                        <RotateTransform Angle="0"/>
                                                                    </Ellipse.RenderTransform>
                                                                    <Ellipse.Triggers>
                                                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                                                     From="0" To="360" Duration="0:0:16" RepeatBehavior="Forever"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </Ellipse.Triggers>
                                                                </Ellipse>
                                                                <Ellipse Width="92" Height="92" Stroke="{DynamicResource LineDimBrush}" StrokeThickness="1"/>
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding CapacityPercent, StringFormat=N0}" Style="{DynamicResource DisplayTextStyle}" FontSize="28" HorizontalAlignment="Center"/>
                                                                        <TextBlock Text="%" Style="{DynamicResource DisplayTextStyle}" FontSize="18" VerticalAlignment="Bottom" Margin="3,0,0,4"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding CapacityUsedDisplay}" Style="{DynamicResource MicroTextStyle}" HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="POOL SLOTS" Style="{DynamicResource MicroTextStyle}" HorizontalAlignment="Center" FontSize="9"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </DockPanel>
                    </Border>
                    <!-- Bottom: Trusted certs table -->
                    <Border Style="{DynamicResource HudPanelStyle}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                                <TextBlock Text="&gt;&gt; TRUSTED CERTS - TOFU" Style="{DynamicResource SectionHeaderTextStyle}"/>
                            </Border>
                            <Grid>
                                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                                <DataGrid ItemsSource="{Binding TrustedCerts}" AutoGenerateColumns="False"
                                          Margin="14" Background="Transparent" HeadersVisibility="Column"
                                          CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="HOST" Binding="{Binding HostKey}" Width="240"/>
                                        <DataGridTextColumn Header="SUBJECT" Binding="{Binding Subject}" Width="*"/>
                                        <DataGridTextColumn Header="ISSUER" Binding="{Binding Issuer}" Width="*"/>
                                        <DataGridTextColumn Header="FINGERPRINT (SHA-256)" Binding="{Binding Fingerprint}" Width="220"/>
                                        <DataGridTextColumn Header="NOT AFTER" Binding="{Binding NotAfter}" Width="160"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- World Monitor Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="13" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="World Monitor" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <ui:WebViewHost x:Name="WorldMonitorHost"/>
            </TabItem>

            <!-- Discord Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="14" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Discord" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <ui:WebViewHost x:Name="DiscordHost"/>
            </TabItem>

            <!-- Streems Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="15" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Streems" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <ui:WebViewHost x:Name="StreemsHost"/>
            </TabItem>

            <!-- AI Agent Tab -->
            <TabItem>
                <TabItem.Header>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="16" Style="{DynamicResource MicroTextStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="AI Agent" VerticalAlignment="Center"/>
                    </Grid>
                </TabItem.Header>
                <ui:AgentView/>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="&#x2699; Settings" Click="Settings_Click"
                        Padding="10,3" Style="{StaticResource SecondaryButton}" FontSize="12"
                        VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusBarSpeed}" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="SemiBold" Margin="0,0,20,0" FontSize="12"/>
                    <TextBlock Text="{Binding StatusBarQueueCount}" Foreground="{DynamicResource ForegroundDimBrush}"
                               Margin="0,0,20,0" FontSize="12"/>
                    <TextBlock Text="{Binding StatusBarDiskSpace}" Foreground="{DynamicResource ForegroundDimBrush}"
                               FontSize="12"/>
                    <TextBlock Text="{Binding Irc.StatusText}" Foreground="{DynamicResource ForegroundDimBrush}"
                               Margin="20,0,0,0" FontSize="12"/>
                    <TextBlock Text="{Binding StatusBarConnections}" Foreground="{DynamicResource ForegroundDimBrush}"
                               Margin="20,0,0,0" FontSize="12"/>
                    <TextBlock Text="{Binding StatusBarSites}" Foreground="{DynamicResource ForegroundDimBrush}"
                               Margin="20,0,0,0" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================================================== -->
        <!-- BOTTOM MARQUEE STRIP (scrolling status feed)                    -->
        <!-- ============================================================== -->
        <Border Grid.Row="3" Background="{DynamicResource MarqueeBackgroundBrush}"
                BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,1,0,0"
                ClipToBounds="True">
            <Border.Resources>
                <Storyboard x:Key="MarqueeLocalStoryboard" RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="MarqueeText"
                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                    From="0" To="-2400" Duration="0:1:00"/>
                </Storyboard>
            </Border.Resources>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard Storyboard="{StaticResource MarqueeLocalStoryboard}"/>
                </EventTrigger>
            </Border.Triggers>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="14,0,0,0">
                    <Ellipse Width="6" Height="6" Fill="{DynamicResource GoodBrush}" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="SYS:ONLINE" FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="10" Foreground="{DynamicResource TextDimBrush}"/>
                </StackPanel>

                <Canvas Grid.Column="1" ClipToBounds="True" Margin="18,0">
                    <TextBlock x:Name="MarqueeText"
                               Canvas.Top="6"
                               TextWrapping="NoWrap"
                               FontFamily="{DynamicResource MonoFontFamily}"
                               FontSize="10"
                               Foreground="{DynamicResource TextDimBrush}"
                               Text="[RX] 12.4 MB/s  //  [TX] 4.1 MB/s  //  ZEPHYR RTT 38ms  //  SUPERBNC RTT 14ms  //  SPREAD ACTIVE: 4  //  POOL 18/24  //  NODE CRADLE ENGAGED  //  KERNEL OK  //  [RX] 12.4 MB/s  //  [TX] 4.1 MB/s  //  ZEPHYR RTT 38ms  //  SUPERBNC RTT 14ms  //  SPREAD ACTIVE: 4  //  POOL 18/24  //  NODE CRADLE ENGAGED  //  KERNEL OK  //  ">
                        <TextBlock.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,14,0">
                    <!-- Live RTT / RX / TX. RxRateDisplay and TxRateDisplay are
                         driven by the same 2-second TickOverview that powers the
                         Overview tab's throughput panel; RxRateDisplay sums all
                         active download BytesPerSecond, TxRateDisplay sums all
                         spread-job non-source SpeedBps. StatusBarRtt comes from
                         the ConnectionMonitor average across mounted servers. -->
                    <TextBlock Text="RTT " FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                               Foreground="{DynamicResource TextDimBrush}"/>
                    <TextBlock Text="{Binding StatusBarRtt, FallbackValue=--ms}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,14,0"/>
                    <TextBlock Text="&#x2193; " FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                               Foreground="{DynamicResource TextDimBrush}"/>
                    <TextBlock Text="{Binding RxRateDisplay, FallbackValue=0.0 MB/s}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                               Foreground="{DynamicResource GoodBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="&#x2191; " FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                               Foreground="{DynamicResource TextDimBrush}"/>
                    <TextBlock Text="{Binding TxRateDisplay, FallbackValue=0.0 MB/s}" FontFamily="{DynamicResource MonoFontFamily}" FontSize="10"
                               Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Keyboard shortcuts overlay (toggle with `?`) -->
        <Border x:Name="ShortcutsOverlay" Grid.RowSpan="4"
                Background="#CC03070D"
                Visibility="Collapsed" Panel.ZIndex="9999"
                MouseLeftButtonDown="ShortcutsOverlay_Click">
            <Border MaxWidth="640" Padding="32" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#F00B1828" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#00E5FF" BlurRadius="28" ShadowDepth="0" Opacity="0.55"/>
                </Border.Effect>
                <Grid>
                    <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                    <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                    <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                    <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                    <StackPanel Margin="12">
                        <TextBlock Text="&gt;&gt; KEYBOARD SHORTCUTS"
                                   Style="{DynamicResource SectionHeaderTextStyle}"
                                   FontSize="16" Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="?  /  Shift+/" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Toggle this overlay" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Esc" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Close overlay" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+Tab" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Next tab" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+Shift+Tab" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Previous tab" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Enter (IRC)" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Send message in the IRC input" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Tab (IRC)" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Nick completion / cycle through matches" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Delete (Downloads)" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="Cancel selected download(s)" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="R (Downloads)" Style="{DynamicResource AccentTextStyle}" Margin="0,4"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" Text="Retry selected failed download(s)" Style="{DynamicResource DimTextStyle}" Margin="14,4"/>
                        </Grid>
                        <TextBlock Text="Click anywhere to dismiss"
                                   Style="{DynamicResource MicroTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,18,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
