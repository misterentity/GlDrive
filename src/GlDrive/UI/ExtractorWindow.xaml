<Window x:Class="GlDrive.UI.ExtractorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Extract Archives" Width="820" Height="580"
        MinWidth="650" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Window.Resources>
        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Add Files" Click="AddFiles_Click" Padding="14,5" Margin="0,0,4,0"
                    Style="{StaticResource PrimaryButton}" FontSize="11"/>
            <Button Content="Add Folder" Click="AddFolder_Click" Padding="14,5" Margin="0,0,4,0"
                    Style="{StaticResource SecondaryButton}" FontSize="11"/>
            <Button Content="Remove" Click="Remove_Click" Padding="14,5" Margin="0,0,4,0"
                    Style="{StaticResource SecondaryButton}" FontSize="11"/>
            <Button Content="Clear All" Click="ClearAll_Click" Padding="14,5" Margin="0,0,16,0"
                    Style="{StaticResource SecondaryButton}" FontSize="11"/>
            <Button x:Name="ExtractButton" Content="Extract All" Click="Extract_Click" Padding="18,5" Margin="0,0,4,0"
                    Style="{StaticResource PrimaryButton}" FontSize="11" FontWeight="SemiBold"/>
            <Button Content="Clean Folders" Click="CleanFolders_Click" Padding="14,5"
                    Style="{StaticResource SecondaryButton}" FontSize="11"
                    ToolTip="Scan folders for leftover archives after extraction"/>
        </StackPanel>

        <!-- Archive list -->
        <DataGrid Grid.Row="1" x:Name="ArchiveGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                  RowBackground="{DynamicResource SurfaceBrush}"
                  AlternatingRowBackground="{DynamicResource SurfaceLightBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Archive" Binding="{Binding FileName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Type" Binding="{Binding ArchiveType}" Width="55"/>
                <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" Width="70"/>
                <DataGridTextColumn Header="Files" Binding="{Binding EntryCount}" Width="45"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="4,2"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Done">
                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Error">
                                    <Setter Property="Foreground" Value="#F44336"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Extracting">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="Progress" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" Height="14"
                                         Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource AccentBrush}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Drop hint overlay (shown when list is empty) -->
        <TextBlock Grid.Row="1" x:Name="DropHint"
                   Text="Drag &amp; drop archive files or folders here"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="15" Foreground="{DynamicResource ForegroundDimBrush}"
                   IsHitTestVisible="False"/>

        <!-- Settings -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Watch folders -->
                <DockPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,6">
                    <TextBlock Text="Watch:" Style="{StaticResource SmallLabel}" Width="55"/>
                    <ToggleButton x:Name="WatchToggle" DockPanel.Dock="Right" Content="Off" Click="WatchToggle_Click"
                                  Padding="10,2" Margin="6,0,0,0" FontSize="11" Width="50"/>
                    <Button DockPanel.Dock="Right" Content="+" Click="AddWatchFolder_Click" Padding="8,2" Margin="6,0,0,0"
                            Style="{StaticResource SecondaryButton}" FontSize="11" ToolTip="Add watch folder"/>
                    <TextBox x:Name="WatchFoldersText" FontSize="11" Padding="4,3" IsReadOnly="True"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource ForegroundDimBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             ToolTip="Folders being monitored for new archives (click + to add)"/>
                </DockPanel>

                <!-- Row 1: Output folder -->
                <DockPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,6">
                    <TextBlock Text="Output:" Style="{StaticResource SmallLabel}" Width="55"/>
                    <Button DockPanel.Dock="Right" Content="..." Click="BrowseOutput_Click" Padding="8,2" Margin="6,0,0,0"
                            Style="{StaticResource SecondaryButton}" FontSize="11"/>
                    <ComboBox x:Name="OutputMode" DockPanel.Dock="Right" Width="140" Margin="6,0,0,0"
                              SelectedIndex="0" FontSize="11"
                              Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource ForegroundBrush}">
                        <ComboBoxItem Content="Same as archive"/>
                        <ComboBoxItem Content="Archive subfolder"/>
                        <ComboBoxItem Content="Custom folder"/>
                    </ComboBox>
                    <TextBox x:Name="CustomOutputPath" FontSize="11" Padding="4,3"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </DockPanel>

                <!-- Row 2: Options -->
                <WrapPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkDeleteAfter" Content="Delete after extract" Margin="0,0,14,0"
                              Foreground="{DynamicResource ForegroundBrush}" FontSize="11"
                              Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ChkRecursive" Content="Scan subfolders" Margin="0,0,14,0"
                              Foreground="{DynamicResource ForegroundBrush}" FontSize="11" IsChecked="True"
                              Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <CheckBox x:Name="ChkCreateSubfolder" Content="Create subfolder per archive" Margin="0,0,14,0"
                              Foreground="{DynamicResource ForegroundBrush}" FontSize="11"
                              Checked="Settings_Changed" Unchecked="Settings_Changed"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                        <TextBlock Text="Overwrite:" Style="{StaticResource SmallLabel}" Margin="0,0,4,0"/>
                        <ComboBox x:Name="OverwriteMode" Width="90" SelectedIndex="0" FontSize="11"
                                  Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource ForegroundBrush}">
                            <ComboBoxItem Content="Overwrite"/>
                            <ComboBoxItem Content="Skip"/>
                            <ComboBoxItem Content="Rename"/>
                        </ComboBox>
                    </StackPanel>
                </WrapPanel>

                <!-- Password -->
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Password:" Style="{StaticResource SmallLabel}" Margin="0,0,4,0"/>
                    <PasswordBox x:Name="ArchivePassword" Width="120" FontSize="11" Padding="4,3"
                                 Background="{DynamicResource SurfaceBrush}"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="3" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusText" FontSize="11"
                       Foreground="{DynamicResource ForegroundDimBrush}" VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1" x:Name="TotalProgress" Width="200" Height="14" Margin="8,0"
                         Minimum="0" Maximum="100"
                         Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Grid.Column="2" x:Name="TotalProgressText" FontSize="11" Width="45"
                       Foreground="{DynamicResource ForegroundDimBrush}" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
