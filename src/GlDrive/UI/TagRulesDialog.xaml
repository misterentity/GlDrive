<Window x:Class="GlDrive.UI.TagRulesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tag Rules" Width="820" Height="620"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Border Margin="14" Style="{DynamicResource HudPanelStyle}">
        <DockPanel>
            <Border DockPanel.Dock="Top" Style="{DynamicResource HudPanelHeaderStyle}">
                <TextBlock Text="&gt;&gt; TAG RULES" Style="{DynamicResource SectionHeaderTextStyle}"/>
            </Border>
            <Grid Margin="12">
                <Border Style="{DynamicResource HudCornerBracketTLStyle}"/>
                <Border Style="{DynamicResource HudCornerBracketTRStyle}"/>
                <Border Style="{DynamicResource HudCornerBracketBLStyle}"/>
                <Border Style="{DynamicResource HudCornerBracketBRStyle}"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock x:Name="HeaderText" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock FontSize="11" Foreground="{DynamicResource ForegroundDimBrush}"
                                   TextWrapping="Wrap"
                                   Text="Rules for this mapping. Pattern is a wildcard/regex match against the release name, OR use Expression for RaceTrade-style [key] op value syntax."/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="TagRulesGrid"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Single" GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pattern" Binding="{Binding Pattern}" Width="160"/>
                            <DataGridCheckBoxColumn Header="Rx" Binding="{Binding IsRegex}" Width="40"/>
                            <DataGridTextColumn Header="Expression" Binding="{Binding Expression}" Width="*"/>
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Add" Click="Add_Click" Padding="14,4" Margin="0,0,6,0"/>
                        <Button Content="Remove" Click="Remove_Click" Padding="14,4" Margin="0,0,12,0"/>
                        <Button Content="OK" Click="Ok_Click" Padding="20,4"
                                Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
